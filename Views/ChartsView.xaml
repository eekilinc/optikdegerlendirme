<UserControl x:Class="OptikFormApp.Views.ChartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding Students.Count, Converter={StaticResource DataToVisConverter}}">
            <StackPanel Margin="20">
                <GroupBox Header="Soru Başarı Oranları (Net Doğru %)" BorderThickness="0" Foreground="{DynamicResource TextMain}">
                    <Border Height="250" Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="10">
                        <ItemsControl ItemsSource="{Binding AccuracyData}" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Margin="2,0">
                                        <Border Width="12" Height="{Binding Value, Converter={StaticResource ValueHeightConverter}, ConverterParameter=2}" VerticalAlignment="Bottom" CornerRadius="4,4,0,0" ToolTip="{Binding Tooltip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Text="{Binding Label}" FontSize="8" HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </GroupBox>

                <GroupBox Header="Puan Dağılımı (Öğrenci Sayısı)" BorderThickness="0" Foreground="{DynamicResource TextMain}" Margin="0,30,0,0">
                    <Border Height="200" Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15">
                        <ItemsControl ItemsSource="{Binding ScoreDistData}" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="11" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Bottom">
                                        <Border Width="25" Height="{Binding Value, ConverterParameter=20, Converter={StaticResource ValueHeightConverter}}" VerticalAlignment="Bottom" Background="#3B82F6" CornerRadius="4,4,0,0" ToolTip="{Binding Tooltip}"/>
                                        <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- EMPTY STATE: CHARTS -->
        <Border Visibility="{Binding Students.Count, Converter={StaticResource CountToVisConverter}}" 
                VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
            <StackPanel>
                <Border Width="80" Height="80" Background="{DynamicResource AltRowBg}" CornerRadius="40" Margin="0,0,0,20">
                    <TextBlock Text="📈" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Text="Grafik Raporu Yok" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                <TextBlock Text="Puan dağılımı ve başarı grafiklerini görebilmek için önce veri yüklemelisiniz." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,10,0,25" TextAlignment="Center"/>
                <Button Content="Hemen Veri Yükle" Command="{Binding LoadTxtCommand}" Style="{StaticResource PipelineButton}" 
                        Background="#3B82F6" Foreground="White" Padding="25,12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
