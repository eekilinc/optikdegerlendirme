<Window x:Class="OptikFormApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptikFormApp.ViewModels"
        Title="MAKÜ Optik Değerlendirme (Premium Modals)" Height="800" Width="1250"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource AppBg}" FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:AnswerStateToBrushConverter x:Key="AnswerStateConverter"/>
        <vm:CountToVisibilityConverter x:Key="CountToVisConverter"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PipelineButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Background="{DynamicResource CardBg}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="4">
                            <Grid>
                                <ContentPresenter x:Name="menuHeaderContainer" ContentTemplate="{TemplateBinding HeaderTemplate}" Content="{TemplateBinding Header}" ContentStringFormat="{TemplateBinding HeaderStringFormat}" ContentSource="Header" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="Fade" Placement="Bottom">
                                    <Border x:Name="SubMenuBorder" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6" Margin="0,5,0,0" Padding="5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <ScrollViewer x:Name="SubMenuScrollViewer" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                            <Grid RenderOptions.ClearTypeHint="Enabled">
                                                <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle"/>
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="PART_Popup" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="{DynamicResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Fill="{TemplateBinding Background}" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AltRowBg}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- APP SHELL -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Top Menu -->
                <RowDefinition Height="*"/>    <!-- Main View -->
            </Grid.RowDefinitions>

            <!-- MODERN TOP MENU -->
            <Border Grid.Row="0" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                <Menu Background="Transparent" Padding="10,5">
                    <MenuItem Header="_Dosya">
                        <MenuItem Header="Optik Verisi Yükle (.txt)" Command="{Binding LoadTxtCommand}"/>
                        <MenuItem Header="Sonuçları Dışa Aktar (.xlsx)" Command="{Binding ExportExcelCommand}"/>
                        <Separator/>
                        <MenuItem Header="Çıkış" Command="{Binding ExitCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_İşlemler">
                        <MenuItem Header="Cevap Anahtarlarını Yönet" Command="{Binding OpenModalCommand}"/>
                        <MenuItem Header="Puanları Hesapla" Command="{Binding EvaluateCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Seçenekler">
                        <MenuItem Header="Arayüz Ayarları..." Command="{Binding OpenSettingsCommand}"/>
                        <MenuItem Header="Genel Konfigürasyon..." Command="{Binding OpenSettingsCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Yardım">
                        <MenuItem Header="Uygulama Hakkında..." Command="{Binding OpenAboutCommand}"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- MODERN WORKFLOW ACTION BAR -->
                <Border Grid.Row="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="15" ShadowDepth="2"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Title -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="Değerlendirme Kontrol Paneli" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                            <TextBlock Text="Optik okuma, test hesaplama ve raporlama adımlarını sırasıyla yönetin." FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Right: Action Pipeline -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            
                            <Button Command="{Binding OpenModalCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,20,0" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBlock Text="Cevap Anahtarı"/>
                                </StackPanel>
                            </Button>
                            
                            <Rectangle Width="1" Fill="{DynamicResource Border}" Margin="0,5,20,5"/>

                            <Button Command="{Binding LoadTxtCommand}" Style="{StaticResource PipelineButton}" Background="{DynamicResource AltRowBg}" BorderBrush="{DynamicResource Border}" Foreground="{DynamicResource TextMain}" Margin="0,0,10,0" Padding="20,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" Margin="0,0,8,0"/>
                                    <TextBlock Text="1. Dosya Yükle" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding EvaluateCommand}" Style="{StaticResource PipelineButton}" Background="#10B981" BorderBrush="#059669" Foreground="White" Margin="0,0,10,0" Padding="20,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" Margin="0,0,8,0"/>
                                    <TextBlock Text="2. Hesapla" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ExportExcelCommand}" Style="{StaticResource PipelineButton}" Background="#F59E0B" BorderBrush="#D97706" Foreground="White" Padding="20,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" Margin="0,0,8,0"/>
                                    <TextBlock Text="3. Excel'e Aktar" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TAB CONTROL -->
                <Border Grid.Row="1" CornerRadius="12" Background="{DynamicResource CardBg}" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="15" ShadowDepth="2"/>
                    </Border.Effect>

                    <TabControl Background="Transparent" BorderThickness="0" Margin="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" Padding="20,12" BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="{DynamicResource CardBg}">
                                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                                    <Setter Property="TextElement.Foreground" Value="#3B82F6"/>
                                                    <Setter Property="TextElement.FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource TextMuted}"/>
                                                    <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextElement.Foreground" Value="#3B82F6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- TAB 1: STUDENTS -->
                        <TabItem Header="İşlem Kayıtları">
                            <Grid>
                                <DataGrid ItemsSource="{Binding Students}" RowHeight="{Binding GridRowHeight}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="{Binding DataContext.GridCellPadding, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="ÖĞRENCİ NO" Binding="{Binding StudentId}" Width="130"/>
                                        <DataGridTextColumn Header="AD SOYAD" Binding="{Binding FullName}" Width="220"/>
                                        <DataGridTextColumn Header="KİTAPÇIK" Binding="{Binding BookletType}" Width="85">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        
                                        <DataGridTemplateColumn Header="ÖĞRENCİ CEVAPLARI" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ItemsControl ItemsSource="{Binding ColoredAnswers}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Character}" Foreground="{Binding State, Converter={StaticResource AnswerStateConverter}}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,1,0"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="D" Binding="{Binding CorrectCount}" Width="50"/>
                                        <DataGridTextColumn Header="Y" Binding="{Binding IncorrectCount}" Width="50"/>
                                        <DataGridTextColumn Header="B" Binding="{Binding EmptyCount}" Width="50"/>
                                        <DataGridTextColumn Header="NET PUAN" Binding="{Binding Score, StringFormat={}{0:N2}}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- EMPTY STATE: STUDENTS -->
                                <StackPanel Visibility="{Binding Students.Count, Converter={StaticResource CountToVisConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📂 Veri Bulunamadı" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Henüz veri listelenmiyor. Dosya yüklemek için üstteki 'Dosya Yükle' butonunu kullanın." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- TAB 2: STATISTICS -->
                        <TabItem Header="Sınav İstatistikleri (Madde Analizi)">
                            <Grid>
                                <DataGrid ItemsSource="{Binding Statistics}" RowHeight="{Binding GridRowHeight}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="{Binding DataContext.GridCellPadding, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ktp" Binding="{Binding Booklet}" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Soru" Binding="{Binding QuestionNumber}" Width="60">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Cevap" Binding="{Binding CorrectAnswer}" Width="60">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        
                                        <DataGridTextColumn Header="% Doğru" Binding="{Binding CorrectPercent, StringFormat={}{0:N2}%}" Width="85">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="% Yanlış" Binding="{Binding IncorrectPercent, StringFormat={}{0:N2}%}" Width="85">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="% Boş" Binding="{Binding EmptyPercent, StringFormat={}{0:N2}%}" Width="75">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="A" Binding="{Binding CountA}" Width="60"/>
                                        <DataGridTextColumn Header="B" Binding="{Binding CountB}" Width="60"/>
                                        <DataGridTextColumn Header="C" Binding="{Binding CountC}" Width="60"/>
                                        <DataGridTextColumn Header="D" Binding="{Binding CountD}" Width="60"/>
                                        <DataGridTextColumn Header="E" Binding="{Binding CountE}" Width="60"/>
                                        <DataGridTextColumn Header="Boş" Binding="{Binding CountEmpty}" Width="60"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- EMPTY STATE: STATISTICS -->
                                <StackPanel Visibility="{Binding Statistics.Count, Converter={StaticResource CountToVisConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📊 İstatistik Raporu Yok" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Analiz edebilmek için lütfen cevap anahtarını yükleyin ve Puanları Hesaplayın." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <!-- Minimalist Status Bar -->
                <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="8" Margin="0,20,0,0" Padding="15,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="5" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Durum:" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMain}" FontSize="14"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- BOOKLET SETTINGS MODAL OVERLAY -->
        <Grid Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="100">
            <Border Background="{DynamicResource CardBg}" CornerRadius="16" Width="650" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="30" ShadowDepth="10"/>
                </Border.Effect>
                
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,20">
                        <TextBlock Text="Cevap Anahtarı Yönetimi" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMain}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="X" Command="{Binding CloseModalCommand}" Background="Transparent" Foreground="{DynamicResource TextMuted}" FontSize="18" Padding="10,5" DockPanel.Dock="Right" ToolTip="Kapat" Margin="0,-10,-10,0"/>
                    </DockPanel>

                    <TextBlock Text="Kitapçık türlerine göre cevap şablonlarını aşağıdan ekleyip silebilirsiniz." Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AnswerKeys}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource AltRowBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,15,0">
                                                <TextBlock Text="Kitapçık:" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding BookletName, UpdateSourceTrigger=PropertyChanged}" Width="50" ToolTip="Örn: A" TextAlignment="Center" FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,15,0">
                                                <TextBlock Text="Cevap Anahtarı Karakterleri:" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Answers, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" MinWidth="300" HorizontalAlignment="Stretch"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Command="{Binding DataContext.RemoveAnswerKeyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderBrush="#EF4444" BorderThickness="1" Foreground="#EF4444" Content="Sil" Padding="15,8" VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="+ Yeni Ekle" Command="{Binding AddAnswerKeyCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,15,0"/>
                        <Button Content="Kaydet ve Kapat" Command="{Binding CloseModalCommand}" Background="#10B981" Padding="25,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MODERN ALERT OVERLAY -->
        <Grid Visibility="{Binding IsAlertOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="200">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding AlertTitle}" FontSize="20" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,0,15"/>
                    <TextBlock Text="{Binding AlertMessage}" FontSize="15" Foreground="{DynamicResource TextMain}" TextWrapping="Wrap" Margin="0,0,0,25" LineHeight="22"/>
                    <Button Content="Tamam, Anladım" Command="{Binding CloseAlertCommand}" Background="#10B981" HorizontalAlignment="Right" Padding="20,10"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SETTINGS OVERLAY -->
        <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="300">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,20">
                        <TextBlock Text="⚙️ Tercihler ve Ayarlar" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="X" Command="{Binding CloseSettingsCommand}" Background="Transparent" Foreground="{DynamicResource TextMuted}" FontSize="18" Padding="10,5" DockPanel.Dock="Right" ToolTip="Kapat" Margin="0,-10,-10,0"/>
                    </DockPanel>

                    <TextBlock Text="Arayüz Seçenekleri" FontWeight="SemiBold" Foreground="#3B82F6" Margin="0,0,0,10" FontSize="15"/>
                    <Rectangle Height="1" Fill="{DynamicResource Border}" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Sistem Teması:" Width="150" VerticalAlignment="Center" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                        <ComboBox SelectedIndex="{Binding ThemeIndex}" Width="200" Padding="8,4" Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextMain}">
                            <ComboBoxItem Content="☀️ Açık Tema"/>
                            <ComboBoxItem Content="🌙 Karanlık Tema"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <TextBlock Text="Tablo Yerleşimi:" Width="150" VerticalAlignment="Center" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                        <ComboBox SelectedIndex="{Binding LayoutIndex}" Width="200" Padding="8,4" Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextMain}">
                            <ComboBoxItem Content="Kompakt Görünüm"/>
                            <ComboBoxItem Content="Geniş ve Rahat"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="Genel Konfigürasyon" FontWeight="SemiBold" Foreground="#3B82F6" Margin="0,0,0,10" FontSize="15"/>
                    <Rectangle Height="1" Fill="{DynamicResource Border}" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Excel Çıktı Klasörü:" Width="150" VerticalAlignment="Center" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                        <TextBox Width="120" Margin="0,0,10,0" IsReadOnly="True" Text="{Binding DefaultExcelPath, Mode=TwoWay}" Foreground="{DynamicResource TextMuted}" Background="{DynamicResource AppBg}"/>
                        <Button Content="Dizin Seç..." Command="{Binding SelectFolderCommand}" Padding="15,6" Style="{StaticResource OutlineButton}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                        <Button Content="Kaydet ve Kapat" Command="{Binding CloseSettingsCommand}" Background="#10B981" Padding="25,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ABOUT OVERLAY -->
        <Grid Visibility="{Binding IsAboutOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="300">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40,35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🎓" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Optik Değerlendirme" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Sürüm 1.0.0 (Premium Edit)" FontSize="13" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Geliştirici" FontWeight="SemiBold" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="Ekrem Kılınç (eekilinc)" Foreground="{DynamicResource TextMain}" FontSize="15" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <Rectangle Height="1" Fill="{DynamicResource Border}" Margin="0,0,0,15"/>
                    <TextBlock Text="Bu yazılım öğrenci sınav sonuçlarını yüksek doğrulukla çözümlemek ve madde analizi üretmek vizyonuyla geliştirilmiştir." TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,25" LineHeight="20"/>

                    <Button Content="Pencereyi Kapat" Command="{Binding CloseAboutCommand}" Style="{StaticResource OutlineButton}"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
