<UserControl x:Class="OptikFormApp.Views.Modals.DetailedAnswerKeyEditorModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="650">
    
    <Grid Visibility="{Binding IsDetailedAnswerKeyEditorOpen, Converter={StaticResource BoolToVis}}" 
          Background="#CC000000">
        
        <!-- Compact Modal -->
        <Border Width="620" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                CornerRadius="16"
                Padding="0"
                MaxHeight="500">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="40" ShadowDepth="15"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" 
                        Height="60"
                        CornerRadius="16,16,0,0" 
                        Padding="16,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="20" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Detaylı Cevap Anahtarı" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding SelectedAnswerKeyForEdit.BookletName, StringFormat='Kitapçık {0}'}" 
                                           FontSize="11" 
                                           Foreground="#BFDBFE"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Button Command="{Binding CloseDetailedAnswerKeyEditorCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Background="#20FFFFFF" 
                                BorderThickness="0" 
                                Foreground="White"
                                Width="28" 
                                Height="28"
                                FontSize="12" 
                                Padding="0"
                                Cursor="Hand">
                            <Button.Content>✕</Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="14"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Toolbar with Add/Remove -->
                <Border Grid.Row="1" 
                        Padding="12,10"
                        BorderThickness="0,0,0,1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#334155"/>
                                    <Setter Property="BorderBrush" Value="#475569"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <StackPanel Orientation="Horizontal">
                        <!-- Add/Remove Question Buttons -->
                        <Button Content="➕ Soru Ekle" 
                                Command="{Binding AddQuestionToAnswerKeyCommand}"
                                Padding="10,5"
                                Background="#10B981"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Margin="0,0,6,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="➖ Son Soruyu Sil" 
                                Command="{Binding RemoveLastQuestionFromAnswerKeyCommand}"
                                Padding="10,5"
                                Background="#EF4444"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Margin="0,0,6,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Border Width="1" 
                                Background="#CBD5E1" 
                                Margin="6,0"/>
                        
                        <Button Content="📋 Toplu Giriş" 
                                Command="{Binding OpenBulkAnswerEntryCommand}"
                                Padding="10,5"
                                Background="#8B5CF6"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Margin="6,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="📊 Analiz" 
                                Command="{Binding AnalyzeAnswerKeyCommand}"
                                Padding="10,5"
                                Background="#F59E0B"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Margin="6,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <TextBlock Text="{Binding SelectedAnswerKeyForEdit.AnswerDetails.Count, StringFormat='{}{0} Soru'}" 
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontWeight="Bold"
                                   FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Content: Compact Answer List -->
                <ScrollViewer Grid.Row="2" 
                              VerticalScrollBarVisibility="Auto"
                              Margin="12,10">
                    <ItemsControl ItemsSource="{Binding SelectedAnswerKeyForEdit.AnswerDetails}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" 
                                        Padding="8,6"
                                        Margin="3"
                                        BorderThickness="1"
                                        Width="75"
                                        Height="65">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter Property="Background" Value="#0F172A"/>
                                                    <Setter Property="BorderBrush" Value="#334155"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Question Number -->
                                        <TextBlock Grid.Row="0" 
                                                   Text="{Binding QuestionNumber, StringFormat='S{0}'}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <!-- Answer Input -->
                                        <TextBox Grid.Row="1" 
                                                 Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="18"
                                                 FontWeight="Bold"
                                                 MaxLength="1"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Padding="0"
                                                 CharacterCasing="Upper">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Setter Property="CaretBrush" Value="#3B82F6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                            <Setter Property="Background" Value="#1E293B"/>
                                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="3" 
                        CornerRadius="0,0,16,16" 
                        Padding="16,12"
                        BorderThickness="0,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#0F172A"/>
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <TextBlock Text="Her kutuya tıklayıp cevabı değiştirin. Analiz butonu ile istatistikleri görün." 
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="Kaydet ve Kapat" 
                                Command="{Binding CloseDetailedAnswerKeyEditorCommand}"
                                Background="#3B82F6" 
                                Foreground="White"
                                Padding="18,8" 
                                FontSize="12" 
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                HorizontalAlignment="Right"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
