                                        <DataGridTextColumn Header="KİTAPÇIK" Binding="{Binding BookletType}" SortMemberPath="BookletType" Width="Auto">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        
                                        <DataGridTemplateColumn Header="ÖĞRENCİ CEVAPLARI" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ItemsControl ItemsSource="{Binding ColoredAnswers}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Character}" Foreground="{Binding State, Converter={StaticResource AnswerStateConverter}}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,1,0"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="D" Binding="{Binding CorrectCount}" SortMemberPath="CorrectCount" Width="50"/>
                                        <DataGridTextColumn Header="Y" Binding="{Binding IncorrectCount}" SortMemberPath="IncorrectCount" Width="50"/>
                                        <DataGridTextColumn Header="B" Binding="{Binding EmptyCount}" SortMemberPath="EmptyCount" Width="50"/>
                                        <DataGridTextColumn Header="SIRA" Binding="{Binding Rank}" SortMemberPath="Rank" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="NET PUAN" Binding="{Binding Score, StringFormat={}{0:N2}}" SortMemberPath="Score" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- EMPTY STATE: STUDENTS -->
                                <StackPanel Visibility="{Binding Students.Count, Converter={StaticResource CountToVisConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📂 Veri Bulunamadı" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Henüz veri listelenmiyor. Dosya yüklemek için üstteki 'Dosya Yükle' butonunu kullanın." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- TAB 2: STATISTICS -->
                        <TabItem Header="Sınav İstatistikleri (Madde Analizi)">
                            <Grid>
                                <DataGrid ItemsSource="{Binding Statistics}" RowHeight="{Binding GridRowHeight}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="{Binding DataContext.GridCellPadding, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ktp" Binding="{Binding Booklet}" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Soru" Binding="{Binding QuestionNumber}" Width="60">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Cevap" Binding="{Binding CorrectAnswer}" Width="60">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        
                                        <DataGridTextColumn Header="% Doğru" Binding="{Binding CorrectPercent, StringFormat={}{0:N2}%}" Width="85">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="% Yanlış" Binding="{Binding IncorrectPercent, StringFormat={}{0:N2}%}" Width="85">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="% Boş" Binding="{Binding EmptyPercent, StringFormat={}{0:N2}%}" Width="75">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="A" Binding="{Binding CountA}" Width="60"/>
                                        <DataGridTextColumn Header="B" Binding="{Binding CountB}" Width="60"/>
                                        <DataGridTextColumn Header="C" Binding="{Binding CountC}" Width="60"/>
                                        <DataGridTextColumn Header="D" Binding="{Binding CountD}" Width="60"/>
                                        <DataGridTextColumn Header="E" Binding="{Binding CountE}" Width="60"/>
                                        <DataGridTextColumn Header="Boş" Binding="{Binding CountEmpty}" Width="60"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- EMPTY STATE: STATISTICS -->
                                <StackPanel Visibility="{Binding Statistics.Count, Converter={StaticResource CountToVisConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📊 İstatistik Raporu Yok" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Analiz edebilmek için lütfen cevap anahtarını yükleyin ve Puanları Hesaplayın." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- TAB 3: CHARTS -->
                        <TabItem Header="Analiz Grafikleri (Görsel)">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="20">
                                    <GroupBox Header="Soru Başarı Oranları (Net Doğru %)" BorderThickness="0" Foreground="{DynamicResource TextMain}">
                                        <Border Height="250" Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="10">
                                            <ItemsControl ItemsSource="{Binding AccuracyData}" VerticalAlignment="Bottom">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Margin="2,0">
                                                            <Border Width="12" Height="{Binding Value, Converter={StaticResource ValueHeightConverter}, ConverterParameter=2}" VerticalAlignment="Bottom" CornerRadius="4,4,0,0" ToolTip="{Binding Tooltip}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#10B981"/>
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Opacity" Value="0.8"/>
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                            <TextBlock Text="{Binding Label}" FontSize="8" HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </GroupBox>

                                    <GroupBox Header="Puan Dağılımı (Öğrenci Sayısı)" BorderThickness="0" Foreground="{DynamicResource TextMain}" Margin="0,30,0,0">
                                        <Border Height="200" Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15">
                                            <ItemsControl ItemsSource="{Binding ScoreDistData}" VerticalAlignment="Bottom">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="11" VerticalAlignment="Bottom"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Bottom">
                                                            <Border Width="25" Height="{Binding Value, ConverterParameter=20, Converter={StaticResource ValueHeightConverter}}" VerticalAlignment="Bottom" Background="#3B82F6" CornerRadius="4,4,0,0" ToolTip="{Binding Tooltip}"/>
                                                            <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Konu Bazlı Başarı">
                            <Border Background="Transparent" Padding="15">
                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding LearningOutcomes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource AltRowBg}" CornerRadius="10" Margin="0,0,0,12" Padding="20,15">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                                <Border Background="#3B82F6" CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                                                                    <TextBlock Text="{Binding BookletName}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                                            </StackPanel>
                                                            
                                                            <TextBlock Text="{Binding QuestionNumbersRaw, StringFormat='Sorular: {0}'}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                                                            
                                                            <!-- Success Progress Bars -->
                                                            <StackPanel Margin="0,0,25,0">
                                                                <TextBlock Text="{Binding GlobalSuccessRate, StringFormat='Genel Sınıf Başarısı: %{0}'}" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                                                <Grid Height="6" Background="{DynamicResource Border}" Margin="0,0,0,8">
                                                                    <Border Background="#3B82F6" HorizontalAlignment="Left" CornerRadius="3">
                                                                        <Border.Width>
                                                                            <MultiBinding Converter="{StaticResource MultiValuePercentageConverter}">
                                                                                <Binding Path="GlobalSuccessRate"/>
                                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                                            </MultiBinding>
                                                                        </Border.Width>
                                                                    </Border>
                                                                </Grid>

                                                                <TextBlock Text="{Binding SuccessRate, StringFormat='Bu Kitapçık Başarısı: %{0}'}" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                                                <Grid Height="6" Background="{DynamicResource Border}">
                                                                    <Border Background="#10B981" HorizontalAlignment="Left" CornerRadius="3">
                                                                        <Border.Width>
                                                                            <MultiBinding Converter="{StaticResource MultiValuePercentageConverter}">
                                                                                <Binding Path="SuccessRate"/>
                                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                                            </MultiBinding>
                                                                        </Border.Width>
                                                                    </Border>
                                                                </Grid>
                                                            </StackPanel>
                                                        </StackPanel>
 
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding GlobalSuccessRate, StringFormat='{}%{0:F1}'}" FontSize="24" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Text="Genel Başarı" FontSize="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right" Margin="0,-5,0,5"/>
                                                            
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding CorrectCount}" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                                                <TextBlock Text="/" Foreground="{DynamicResource TextMuted}"/>
                                                                <TextBlock Text="{Binding TotalQuestions}" Foreground="{DynamicResource TextMuted}"/>
                                                                <TextBlock Text=" Doğru" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                </Grid>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Border>

                <!-- VALIDATION ALERT PANEL -->
                <Border Grid.Row="2" Visibility="{Binding ValidationIssuesCount, Converter={StaticResource NumericToVis}}" Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1" CornerRadius="12" Margin="0,15,0,-15" Padding="15,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="18" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ValidationIssuesCount, StringFormat='{}{0} Adet Veri Doğrulama Sorunu Tespit Edildi!'}" FontWeight="Bold" Foreground="#991B1B"/>
                            <TextBlock Text="Bazı satırlarda okuma hataları veya eksik işaretlemeler var. Lütfen dosyayı kontrol edin." FontSize="11" Foreground="#B91C1C"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Enhanced Status Bar & Logs -->
                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="15,12" Margin="0,0,10,0">
                        <Border.Effect><DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="5" ShadowDepth="1"/></Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="4" Background="{DynamicResource AltRowBg}" Margin="0,0,12,0" Padding="2">
                                <Image Source="/Assets/app_logo.png" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="Durum:" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMain}" FontSize="14" VerticalAlignment="Center"/>
                            
                            <ItemsControl ItemsSource="{Binding ValidationIssues}" Margin="20,0,0,0">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FEE2E2" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,10,0" ToolTip="{Binding Message}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚠️" Margin="0,0,5,0"/><TextBlock Text="{Binding Title}" Foreground="#B91C1C" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="15,10">
                        <Border.Effect><DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="5" ShadowDepth="1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Text="📄 İşlem Kayıtları" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,5"/>
                            <ScrollViewer Grid.Row="1" Height="80" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Logs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <TextBlock Text="{Binding DisplayTime}" Foreground="{DynamicResource TextMuted}" FontSize="11" Width="55"/>
                                                <TextBlock Text="{Binding Message}" Foreground="{Binding Level, Converter={StaticResource LogLevelConverter}}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- BOOKLET SETTINGS MODAL OVERLAY -->
        <Grid Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="100">
            <Border Background="{DynamicResource CardBg}" CornerRadius="16" Width="650" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="30" ShadowDepth="10"/>
                </Border.Effect>
                
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,20">
                        <TextBlock Text="Cevap Anahtarı Yönetimi" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMain}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="X" Command="{Binding CloseModalCommand}" Background="Transparent" Foreground="{DynamicResource TextMuted}" FontSize="18" Padding="10,5" DockPanel.Dock="Right" ToolTip="Kapat" Margin="0,-10,-10,0"/>
                    </DockPanel>

                    <TextBlock Text="Kitapçık türlerine göre cevap şablonlarını aşağıdan ekleyip silebilirsiniz." Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AnswerKeys}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource AltRowBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,15,0">
                                                <TextBlock Text="Kitapçık:" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding BookletName, UpdateSourceTrigger=PropertyChanged}" Width="50" ToolTip="Örn: A" TextAlignment="Center" FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,15,0">
                                                <TextBlock Text="Cevap Anahtarı Karakterleri:" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Answers, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" MinWidth="300" HorizontalAlignment="Stretch"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Command="{Binding DataContext.RemoveAnswerKeyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderBrush="#EF4444" BorderThickness="1" Foreground="#EF4444" Content="Sil" Padding="15,8" VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="+ Yeni Ekle" Command="{Binding AddAnswerKeyCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,15,0"/>
