        <!-- INTERFACE SETTINGS OVERLAY -->
        <Grid Visibility="{Binding IsUISettingsOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="300">
