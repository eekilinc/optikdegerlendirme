<UserControl x:Class="OptikFormApp.Views.Modals.ItemAnalysisModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OptikFormApp.Views.Modals"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Background="#80000000">
        <Border Background="White" 
                CornerRadius="16" 
                Width="950" 
                Height="650"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" 
                           Text="Gelişmiş Soru Analizi" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="Black"
                           Margin="0,0,0,16"/>

                <!-- Reliability Stats -->
                <Border Grid.Row="1" 
                        Background="#F0F0F0" 
                        CornerRadius="12" 
                        Padding="16"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="KR-20 Güvenirlik" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                            <TextBlock Text="{Binding ReliabilityStats.KR20, StringFormat={}{0:F3}}" 
                                       Foreground="Blue" 
                                       FontSize="20" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Cronbach's Alpha" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                            <TextBlock Text="{Binding ReliabilityStats.CronbachAlpha, StringFormat={}{0:F3}}" 
                                       Foreground="Green" 
                                       FontSize="20" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Soru Sayısı" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                            <TextBlock Text="{Binding ReliabilityStats.QuestionCount}" 
                                       Foreground="Black" 
                                       FontSize="20" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Question Stats DataGrid -->
                    <Border Grid.Column="0" 
                            Background="#F0F0F0" 
                            CornerRadius="12" 
                            Padding="12"
                            Margin="0,0,16,0">
                        <DataGrid ItemsSource="{Binding QuestionStats}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProblematic}" Value="True">
                                            <Setter Property="Background" Value="#30EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Soru" 
                                                    Binding="{Binding QuestionNumber}" 
                                                    Width="50"/>
                                <DataGridTextColumn Header="Zorluk" 
                                                    Binding="{Binding Difficulty, StringFormat={}{0:P0}}" 
                                                    Width="70"/>
                                <DataGridTextColumn Header="Ayırt." 
                                                    Binding="{Binding Discrimination, StringFormat={}{0:F2}}" 
                                                    Width="70"/>
                                <DataGridTextColumn Header="Doğru" 
                                                    Binding="{Binding CorrectRate, StringFormat={}{0:P0}}" 
                                                    Width="70"/>
                                <DataGridTextColumn Header="Boş" 
                                                    Binding="{Binding EmptyRate, StringFormat={}{0:P0}}" 
                                                    Width="60"/>
                                <DataGridTextColumn Header="PB Korel." 
                                                    Binding="{Binding PointBiserialCorrelation, StringFormat={}{0:F2}}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Durum" 
                                                    Binding="{Binding Recommendation}" 
                                                    Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Anomalies Panel -->
                    <Border Grid.Column="1" 
                            Background="#F0F0F0" 
                            CornerRadius="12" 
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" 
                                       Text="Tespit Edilen Anomaliler" 
                                       FontWeight="SemiBold" 
                                       Foreground="Black"
                                       Margin="0,0,0,12"/>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Anomalies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" 
                                                    CornerRadius="8" 
                                                    Padding="12" 
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <TextBlock Grid.Row="0" 
                                                               Text="{Binding FullName}" 
                                                               FontWeight="SemiBold" 
                                                               Foreground="Black"/>
                                                    <TextBlock Grid.Row="1" 
                                                               Text="{Binding StudentId}" 
                                                               FontSize="11" 
                                                               Foreground="Gray"
                                                               Margin="0,2"/>
                                                    <TextBlock Grid.Row="2" 
                                                               Text="{Binding Description}" 
                                                               FontSize="12" 
                                                               Foreground="Red"
                                                               TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <TextBlock Grid.Row="1" 
                                       Text="Anomali tespit edilmedi" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="Gray"
                                       Visibility="{Binding Anomalies.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Footer -->
                <StackPanel Grid.Row="3" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="🔄 Yeniden Analiz Et" 
                            Command="{Binding RunItemAnalysisCommand}"
                            Margin="0,0,12,0"/>
                    <Button Content="Kapat" 
                            Command="{Binding CloseItemAnalysisCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
