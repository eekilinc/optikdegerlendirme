<UserControl x:Class="OptikFormApp.Views.Modals.UISettingsModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="500">
    <Grid Visibility="{Binding IsUISettingsOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="20" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="40" ShadowDepth="12"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#6366F1" CornerRadius="20,20,0,0" Padding="30,25">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="🎨  Arayüz Ayarları" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Görünüm ve yerleşim ayarlarını kişiselleştirin." FontSize="13" Foreground="#C7D2FE" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="✕" Command="{Binding CloseUISettingsCommand}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" BorderThickness="0" Foreground="White"
                                FontSize="18" Padding="8,4" Cursor="Hand" Opacity="0.8"/>
                    </Grid>
                </Border>

                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="25,20,25,10">
                    
                    <!-- Tema Kartı -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}">
                                    <Run Text="🌓  "/> <Run Text="Renk Teması"/>
                                </TextBlock>
                                <TextBlock Text="Açık veya koyu mod arasında geçiş yapın." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding ThemeIndex}" Width="160" Padding="10,8"
                                      Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center">
                                <ComboBoxItem Content="🌞  Aydınlık Tema"/>
                                <ComboBoxItem Content="🌙  Karanlık Tema"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Yerleşim Kartı -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20,16" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}">
                                    <Run Text="📋  "/> <Run Text="Tablo Yerleşimi"/>
                                </TextBlock>
                                <TextBlock Text="Satır yüksekliğini ve hücre boşluğunu ayarlayın." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding LayoutIndex}" Width="160" Padding="10,8"
                                      Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center">
                                <ComboBoxItem Content="📊  Kompakt"/>
                                <ComboBoxItem Content="📄  Geniş / Rahat"/>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{DynamicResource AltRowBg}" CornerRadius="0,0,20,20" Padding="25,15">
                    <Grid>
                        <TextBlock Text="💡  Ayarlar anında uygulanır ve kaydedilir." FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <Button Content="Kapat" Command="{Binding CloseUISettingsCommand}"
                                HorizontalAlignment="Right" Background="#6366F1" Foreground="White"
                                Padding="25,8" FontSize="13"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
