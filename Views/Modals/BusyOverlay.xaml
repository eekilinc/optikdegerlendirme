<UserControl x:Class="OptikFormApp.Views.Modals.BusyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="30" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Opacity="0.1" ShadowDepth="5"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{Binding BusyMessage}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,10" Foreground="#3B82F6" Background="{DynamicResource AltRowBg}" BorderThickness="0"/>
                <TextBlock Text="İşlem yürütülüyor, lütfen bekleyin..." FontSize="13" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
