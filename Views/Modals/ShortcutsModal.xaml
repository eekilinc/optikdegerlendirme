<UserControl x:Class="OptikFormApp.Views.Modals.ShortcutsModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="600">
    
    <UserControl.Resources>
        <Storyboard x:Key="ModalOpenAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <Grid Visibility="{Binding IsShortcutsOpen, Converter={StaticResource BoolToVis}}" 
          Background="#CC000000">
        
        <!-- Premium Modal -->
        <Border Width="580" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                CornerRadius="24"
                Padding="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="60" ShadowDepth="20"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Premium Blue Header -->
                <Border Grid.Row="0" 
                        Height="100"
                        CornerRadius="24,24,0,0" 
                        Padding="28,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="⌨️ Klavye Kısayolları" 
                                       FontSize="26" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Uygulamayı daha hızlı kullanmak için kısayolları öğrenin" 
                                       FontSize="13" 
                                       Foreground="#BFDBFE"
                                       Margin="0,6,0,0"
                                       Opacity="0.9"/>
                        </StackPanel>
                        
                        <Button Command="{Binding CloseShortcutsCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Top"
                                Background="#20FFFFFF" 
                                BorderThickness="0" 
                                Foreground="White"
                                Width="36" 
                                Height="36"
                                FontSize="16" 
                                Padding="0"
                                Cursor="Hand">
                            <Button.Content>✕</Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="18"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Premium Shortcut Cards -->
                <Grid Grid.Row="1" Margin="24,24,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column - File Operations -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" 
                                    Height="36" 
                                    CornerRadius="8"
                                    Background="#DBEAFE"
                                    Margin="0,0,10,0">
                                <TextBlock Text="📂" 
                                           FontSize="18" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Dosya İşlemleri" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#60A5FA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- File Shortcuts -->
                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#EFF6FF" 
                                        BorderBrush="#BFDBFE" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl + O" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#3B82F6"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="TXT Dosyası Yükle" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#EFF6FF" 
                                        BorderBrush="#BFDBFE" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl + S" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#3B82F6"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Sınavı Kaydet" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FFF7ED" 
                                        BorderBrush="#FED7AA" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl + E" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#EA580C"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Excel Raporu Al" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F0FDF4" 
                                        BorderBrush="#BBF7D0" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl+⇧+C" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#16A34A"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="CSV Dışa Aktar" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FDF4FF" 
                                        BorderBrush="#E9D5FF" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl + P" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#7C3AED"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Toplu PDF Karne" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Right Column - Operations -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" 
                                    Height="36" 
                                    CornerRadius="8"
                                    Background="#F3E8FF"
                                    Margin="0,0,10,0">
                                <TextBlock Text="⚡" 
                                           FontSize="18" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="İşlemler" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B5CF6"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#A78BFA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F5F3FF" 
                                        BorderBrush="#DDD6FE" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="F5" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#7C3AED"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Puanları Hesapla" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F0F9FF" 
                                        BorderBrush="#BAE6FD" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="F1" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#0284C7"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Bu Pencereyi Aç" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12" 
                                Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FEF3C7" 
                                        BorderBrush="#FDE68A" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl + Z" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#D97706"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Geri Al (Undo)" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Border CornerRadius="12" 
                                Padding="14,12"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="BorderBrush" Value="#475569"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FCE7F3" 
                                        BorderBrush="#FBCFE8" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="8,4" 
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Ctrl + Y" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="#DB2777"/>
                                </Border>
                                <TextBlock Grid.Column="1" 
                                           Text="Yenile (Redo)" 
                                           FontSize="13" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Premium Footer -->
                <Border Grid.Row="2" 
                        CornerRadius="0,0,24,24" 
                        Padding="24,18"
                        BorderThickness="0,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#0F172A"/>
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Tüm kısayollar Dosya menüsünde de gösterilmektedir" 
                                       FontSize="12"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        
                        <Button Content="Kapat" 
                                Command="{Binding CloseShortcutsCommand}"
                                HorizontalAlignment="Right" 
                                Background="#3B82F6" 
                                Foreground="White"
                                Padding="28,10" 
                                FontSize="13" 
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
