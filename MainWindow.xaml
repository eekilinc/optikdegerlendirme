                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,20">
                        <TextBlock Text="🎨 Arayüz Seçenekleri" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="X" Command="{Binding CloseUISettingsCommand}" Background="Transparent" Foreground="{DynamicResource TextMuted}" FontSize="18" Padding="10,5" DockPanel.Dock="Right" ToolTip="Kapat" Margin="0,-10,-10,0"/>
                    </DockPanel>

                    <TextBlock Text="Uygulamanın görünümünü ve tablo düzenini özelleştirin." Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20" TextWrapping="Wrap"/>
                    <Rectangle Height="1" Fill="{DynamicResource Border}" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Sistem Teması:" Width="150" VerticalAlignment="Center" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                        <ComboBox SelectedIndex="{Binding ThemeIndex}" Width="200" Padding="8,4" Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextMain}">
                            <ComboBoxItem Content="☀️ Açık Tema"/>
                            <ComboBoxItem Content="🌙 Karanlık Tema"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <TextBlock Text="Tablo Yerleşimi:" Width="150" VerticalAlignment="Center" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                        <ComboBox SelectedIndex="{Binding LayoutIndex}" Width="200" Padding="8,4" Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextMain}">
                            <ComboBoxItem Content="Kompakt Görünüm"/>
                            <ComboBoxItem Content="Geniş ve Rahat"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                        <Button Content="Kaydet ve Kapat" Command="{Binding CloseUISettingsCommand}" Background="#10B981" Padding="25,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GENERAL CONFIG OVERLAY -->
        <!-- GENERAL CONFIG MODAL OVERLAY -->
        <Grid Visibility="{Binding IsGeneralConfigOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="500">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="⚙️ Sınav ve Puanlama Ayarları" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,25"/>
                    
                    <TextBlock Text="Okul / Kurum Adı" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SchoolName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" Padding="10,8"/>

                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="📊 Puanlama Parametreleri" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,15"/>

                            <TextBlock Text="Net Hesabı Kuralı (Düşüm)" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                            <ComboBox SelectedIndex="{Binding DeductionRuleIndex}" Margin="0,0,0,15" Padding="10,8">
                                <ComboBoxItem Content="Düşüm Yapılmasın (Net = Doğru)"/>
                                <ComboBoxItem Content="3 Yanlış 1 Doğru (0.33)"/>
                                <ComboBoxItem Content="4 Yanlış 1 Doğru (0.25 - Standart)"/>
                            </ComboBox>
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Net Katsayısı" FontSize="13" Foreground="{DynamicResource TextMain}"/>
                                    <TextBlock Text="Her 1 net kaç puan yapacak?" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding NetCoefficient, UpdateSourceTrigger=PropertyChanged}" Padding="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Taban Puan" FontSize="13" Foreground="{DynamicResource TextMain}"/>
                                    <TextBlock Text="Sınav başlangıç puanı (Örn: 0)" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding BaseScore, UpdateSourceTrigger=PropertyChanged}" Padding="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="Excel Çıktı Klasörü:" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox IsReadOnly="True" Text="{Binding DefaultExcelPath}" Margin="0,0,5,0" Padding="8,5" Foreground="{DynamicResource TextMuted}"/>
                        <Button Grid.Column="1" Content="..." Command="{Binding SelectFolderCommand}" Width="40" Padding="5"/>
                    </Grid>

                    <Button Content="Ayarları Kaydet ve Kapat" Command="{Binding CloseGeneralConfigCommand}" Background="#3B82F6" Padding="20,12" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- QUESTION SETTINGS MODAL OVERLAY -->
        <Grid Visibility="{Binding IsQuestionSettingsOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="400">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="550" Height="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="⚙️ Soru Ayarları" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="Soru iptali veya çoklu doğru seçeneklerini buradan yönetebilirsiniz." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding QuestionSettings}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="Transparent" BorderThickness="0" RowHeaderWidth="0" GridLinesVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kitapçık" Binding="{Binding BookletName}" IsReadOnly="True" Width="60">
                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/></Style></DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="No" Binding="{Binding QuestionNumber}" IsReadOnly="True" Width="40">
                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTemplateColumn Header="İptal (X)" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsCancelled, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Çoklu Aktif" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsMultipleEnabled, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Çoklu Doğru Seçenekler" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding MultipleCorrectAnswers, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding IsMultipleEnabled}"
                                                 ToolTip="Örn: AB (Hem A hem B doğru kabul edilir)" 
                                                 Padding="5,2" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Vazgeç" Command="{Binding CloseQuestionSettingsCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,15,0" Padding="15,8"/>
                        <Button Content="Kaydet ve Kapat" Command="{Binding CloseQuestionSettingsCommand}" Background="#10B981" Padding="25,10"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- LEARNING OUTCOMES MODAL OVERLAY -->
        <Grid Visibility="{Binding IsLearningOutcomesOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="500">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="750" Height="650" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="📚 Öğrenim Çıktıları (Konu Yönetimi)" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="Soruları konu başlıklarıyla eşleştirerek detaylı analiz alabilirsiniz." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding LearningOutcomes}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="Transparent" BorderThickness="0" RowHeaderWidth="0" HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Kitapçık" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding BookletName, UpdateSourceTrigger=PropertyChanged}" 
                                                 Padding="5,2" Margin="2" Background="Transparent" BorderThickness="0"
                                                 HorizontalContentAlignment="Center" FontWeight="Bold"
                                                 ToolTip="Kitapçık adı (Örn: A, B)"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Konu/Çıktı Adı" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 Padding="5,2" Margin="2" Background="Transparent" BorderThickness="0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Soru Numaraları" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding QuestionNumbersRaw, UpdateSourceTrigger=PropertyChanged}" 
                                                 Padding="5,2" Margin="2" Background="Transparent" BorderThickness="0" 
                                                 ToolTip="Örn: 1-10, 15, 20-25"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.RemoveOutcomeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Content="🗑️" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Sil"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="+ Yeni Konu Ekle" Command="{Binding AddOutcomeCommand}" Style="{StaticResource OutlineButton}" Foreground="#8B5CF6" BorderBrush="#8B5CF6" Margin="0,0,15,0"/>
                        <Button Content="Vazgeç" Command="{Binding CloseLearningOutcomesCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,15,0" Padding="15,8"/>
                        <Button Content="Kaydet ve Kapat" Command="{Binding CloseLearningOutcomesCommand}" Background="#10B981" Padding="25,10"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ABOUT OVERLAY -->
        <Grid Visibility="{Binding IsAboutOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="300">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40,35">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <Border CornerRadius="10" ClipToBounds="True" Background="White" Margin="0,-10,0,20">
                        <Image Source="/Assets/about_banner.png" Stretch="Uniform" Height="180"/>
                    </Border>
                    
                    <TextBlock Text="AĞLASUN MYO Optik Değerlendirme" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Gelişmiş Analiz ve Raporlama Sistemi" FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="Geliştirici:" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,0"/>
                        <TextBlock Text="Ekrem Kılınç (eekilinc)" Foreground="{DynamicResource TextMain}" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="GitHub:" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,0"/>
                        <TextBlock Cursor="Hand">
                            <Hyperlink NavigateUri="https://github.com/eekilinc/OptikDegerlendirme" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#3B82F6" TextDecorations="Underline">
                                github.com/eekilinc/OptikDegerlendirme
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                    
                    <Rectangle Height="1" Fill="{DynamicResource Border}" Margin="0,0,0,15"/>
                    <TextBlock Text="Bu yazılım, öğrenci sınav sonuçlarını yüksek doğrulukla çözümlemek, madde analizi üretmek ve dijital karne raporları oluşturmak amacıyla geliştirilmiştir." 
                               TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,25" LineHeight="20"/>
                    <Button Content="Pencereyi Kapat" Command="{Binding CloseAboutCommand}" Style="{StaticResource OutlineButton}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ADD COURSE MODAL OVERLAY -->
        <Grid Visibility="{Binding IsAddCourseOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="600">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="➕ Yeni Ders Ekle" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Ders Kodu" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewCourseCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Ders Adı" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewCourseName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Vazgeç" Command="{Binding CloseAddCourseCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Dersi Ekle" Command="{Binding AddCourseCommand}" Background="#3B82F6" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- RENAME MODAL OVERLAY -->
        <Grid Visibility="{Binding IsRenameModalOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}" Panel.ZIndex="605">
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding RenameModalTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,20"/>
                    
                    <TextBox Text="{Binding RenameInput1, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>
                    
                    <TextBox Text="{Binding RenameInput2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" 
                             Visibility="{Binding ShowRenameInput2, Converter={StaticResource BoolToVis}}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Vazgeç" Command="{Binding CloseRenameModalCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Kaydet" Command="{Binding SaveRenameCommand}" Background="#3B82F6" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
