<UserControl x:Class="OptikFormApp.Views.Modals.QuestionSettingsModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="550">
    <Grid Visibility="{Binding IsQuestionSettingsOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="550" Height="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="⚙️ Soru Ayarları" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                    <TextBlock Text="Soru iptali veya çoklu doğru seçeneklerini buradan yönetebilirsiniz." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding QuestionSettings}" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="Transparent" BorderThickness="0" RowHeaderWidth="0" GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kitapçık" Binding="{Binding BookletName}" IsReadOnly="True" Width="60">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="No" Binding="{Binding QuestionNumber}" IsReadOnly="True" Width="40">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="İptal (X)" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsCancelled, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Çoklu Aktif" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsMultipleEnabled, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Çoklu Doğru Seçenekler" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding MultipleCorrectAnswers, UpdateSourceTrigger=PropertyChanged}" 
                                             IsEnabled="{Binding IsMultipleEnabled}"
                                             ToolTip="Örn: AB (Hem A hem B doğru kabul edilir)" 
                                             Padding="5,2" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Kaydet ve Kapat" Command="{Binding CloseQuestionSettingsCommand}" Background="#10B981" Padding="25,10"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
