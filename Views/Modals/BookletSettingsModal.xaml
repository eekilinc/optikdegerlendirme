<UserControl x:Class="OptikFormApp.Views.Modals.BookletSettingsModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="750">
    
    <UserControl.Resources>
        <Storyboard x:Key="ModalOpenAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <Grid Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}}" 
          Background="#CC000000">
        
        <!-- Premium Modal -->
        <Border Width="680" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                CornerRadius="24"
                Padding="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="60" ShadowDepth="20"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Premium Purple Header -->
                <Border Grid.Row="0" 
                        Height="100"
                        CornerRadius="24,24,0,0" 
                        Padding="28,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#7C3AED" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📝 Cevap Anahtarı Yönetimi" 
                                       FontSize="26" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Kitapçık türlerine göre cevap şablonlarını yönetin" 
                                       FontSize="13" 
                                       Foreground="#E9D5FF"
                                       Margin="0,6,0,0"
                                       Opacity="0.9"/>
                        </StackPanel>
                        
                        <Button Command="{Binding CloseModalCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Top"
                                Background="#20FFFFFF" 
                                BorderThickness="0" 
                                Foreground="White"
                                Width="36" 
                                Height="36"
                                FontSize="16" 
                                Padding="0"
                                Cursor="Hand">
                            <Button.Content>✕</Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="18"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="28,24,28,16">
                    
                    <!-- Info Banner -->
                    <Border CornerRadius="12" 
                            Padding="14,10"
                            Margin="0,0,0,16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F5F3FF"/>
                                <Setter Property="BorderBrush" Value="#DDD6FE"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#4C1D95"/>
                                        <Setter Property="BorderBrush" Value="#6D28D9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Her kitapçık türü için ayrı cevap anahtarı tanımlayabilirsiniz. Öğrencilerin kitapçık türü otomatik olarak algılanır." 
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#7C3AED"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#C4B5FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Answer Keys List -->
                    <ScrollViewer MaxHeight="400" 
                                  VerticalScrollBarVisibility="Auto"
                                  PanningMode="VerticalOnly">
                        <ItemsControl ItemsSource="{Binding AnswerKeys}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="16" 
                                            Padding="18"
                                            Margin="0,0,0,12"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Background" Value="#334155"/>
                                                        <Setter Property="BorderBrush" Value="#475569"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Booklet Name -->
                                            <StackPanel Grid.Column="0" 
                                                        Orientation="Vertical" 
                                                        Margin="0,0,16,0"
                                                        Width="70">
                                                <TextBlock Text="Kitapçık" 
                                                           FontSize="11" 
                                                           Margin="0,0,0,6">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#64748B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Text="{Binding BookletName, UpdateSourceTrigger=PropertyChanged}" 
                                                         FontSize="18"
                                                         FontWeight="Bold"
                                                         Foreground="#7C3AED"
                                                         Background="White"
                                                         BorderBrush="#8B5CF6"
                                                         BorderThickness="2"
                                                         TextAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         Padding="12,8"
                                                         MinWidth="50"
                                                         MinHeight="42"
                                                         ToolTip="Kitapçık tipi (örn: A, B, C)"/>
                                            </StackPanel>

                                            <!-- Answers Input -->
                                            <StackPanel Grid.Column="1" 
                                                        Orientation="Vertical">
                                                <TextBlock Text="Cevap Anahtarı" 
                                                           FontSize="11" 
                                                           Margin="0,0,0,6">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#64748B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Text="{Binding Answers, UpdateSourceTrigger=PropertyChanged}" 
                                                         FontFamily="Consolas" 
                                                         FontSize="14"
                                                         Padding="12,10"
                                                         BorderThickness="1"
                                                         BorderBrush="#E2E8F0">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Setter Property="Foreground" Value="#1E293B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Background" Value="#0F172A"/>
                                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                                    <Setter Property="BorderBrush" Value="#334155"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </StackPanel>

                                            <!-- Buttons StackPanel -->
                                            <StackPanel Grid.Column="2" 
                                                        Orientation="Vertical"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center">
                                                <!-- Detailed Edit Button -->
                                                <Button Command="{Binding DataContext.OpenDetailedAnswerKeyEditorFromBookletCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}"
                                                        Padding="12,8"
                                                        Background="#3B82F6" 
                                                        BorderThickness="0" 
                                                        Foreground="White"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Margin="0,0,0,8"
                                                        Cursor="Hand"
                                                        ToolTip="Detaylı soru düzenleyici">
                                                    <Button.Content>🔍 Detaylı</Button.Content>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                
                                                <!-- Delete Button -->
                                                <Button Command="{Binding DataContext.RemoveAnswerKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}"
                                                        Padding="12,8"
                                                        Background="Transparent" 
                                                        BorderBrush="#EF4444" 
                                                        BorderThickness="1" 
                                                        Foreground="#EF4444"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Cursor="Hand">
                                                    <Button.Content>🗑️ Sil</Button.Content>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Premium Footer -->
                <Border Grid.Row="2" 
                        CornerRadius="0,0,24,24" 
                        Padding="28,20"
                        BorderThickness="0,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#0F172A"/>
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="8" 
                                    Height="8" 
                                    CornerRadius="4"
                                    Background="#8B5CF6"
                                    Margin="0,0,10,0"/>
                            <TextBlock Text="Değişiklikler otomatik kaydedilir" 
                                       FontSize="12"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Content="➕ Yeni Ekle" 
                                    Command="{Binding AddAnswerKeyCommand}"
                                    Padding="18,10"
                                    Background="Transparent"
                                    BorderBrush="#8B5CF6"
                                    BorderThickness="2"
                                    Foreground="#8B5CF6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Margin="0,0,12,0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Button Content="Kaydet ve Kapat" 
                                    Command="{Binding CloseModalCommand}"
                                    Background="#8B5CF6" 
                                    Foreground="White"
                                    Padding="24,10" 
                                    FontSize="13" 
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
