<UserControl x:Class="OptikFormApp.Views.Modals.StudentDetailModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700">
    <Grid Visibility="{Binding IsStudentDetailOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="700" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Öğrenci Detayları" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                    <Button Grid.Column="1" Content="✕" Command="{Binding CloseStudentDetailCommand}" 
                            Style="{StaticResource OutlineButton}" Width="35" Height="35" Padding="0"/>
                </Grid>

                <!-- Student Info Edit Section -->
                <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Student Number -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Öğrenci Numarası" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedStudentDetail.StudentId, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="10,8" FontSize="14" x:Name="StudentIdTextBox"/>
                        </StackPanel>

                        <!-- Full Name -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Ad Soyad" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedStudentDetail.FullName, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="10,8" FontSize="14"/>
                        </StackPanel>

                        <!-- Booklet Type (Read-only) -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Kitapçık" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                            <Border Background="{DynamicResource CardBg}" CornerRadius="4" Padding="12,8" MinWidth="60" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SelectedStudentDetail.BookletType}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Score Summary -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,15,0,0">
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextMuted}">
                                <Run Text="Doğru: "/>
                                <Run Text="{Binding SelectedStudentDetail.CorrectCount}" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                <Run Text="  |  Yanlış: "/>
                                <Run Text="{Binding SelectedStudentDetail.IncorrectCount}" FontWeight="Bold" Foreground="#EF4444"/>
                                <Run Text="  |  Boş: "/>
                                <Run Text="{Binding SelectedStudentDetail.EmptyCount}" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                <Run Text="  |  Net: "/>
                                <Run Text="{Binding SelectedStudentDetail.NetCount, StringFormat={}{0:N2}}" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                <Run Text="  |  Puan: "/>
                                <Run Text="{Binding SelectedStudentDetail.Score, StringFormat={}{0:N2}}" FontWeight="Bold" FontSize="14" Foreground="#3B82F6"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Wrong Answers Section -->
                <TextBlock Text="Yanlış ve Boş Cevaplar" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,10"/>
                
                <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15" MaxHeight="300" Margin="0,0,0,20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedStudentDetail.ColoredAnswers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="45" Height="45" Margin="3" CornerRadius="6" 
                                            Background="{Binding State, Converter={StaticResource AnswerStateToBgConverter}}">
                                        <Grid>
                                            <TextBlock Text="{Binding QuestionNumber}" FontSize="9" 
                                                       Foreground="{DynamicResource TextMuted}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Character}" FontSize="16" FontWeight="Bold" 
                                                       Foreground="{Binding State, Converter={StaticResource AnswerStateConverter}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Vazgeç" Command="{Binding CloseStudentDetailCommand}" 
                            Style="{StaticResource OutlineButton}" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="💾 Değişiklikleri Kaydet" Command="{Binding SaveStudentDetailCommand}" 
                            Background="#3B82F6" Foreground="White" Margin="5,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
