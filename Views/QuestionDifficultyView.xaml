<UserControl x:Class="OptikFormApp.Views.QuestionDifficultyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <DockPanel Background="{DynamicResource CardBg}" LastChildFill="True">

        <!-- Başlık Bölümü - DockPanel.Dock=Top -->
        <StackPanel DockPanel.Dock="Top" Margin="25,25,25,15">

            <!-- Header Section - Kompakt -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="📊 Soru Zorluk Seviyesi Analizi"
                          FontSize="20" FontWeight="Bold"
                          Foreground="{DynamicResource TextMain}" Margin="0,0,0,10"/>

                <!-- Mini Stats - Dengeli Boyut -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <!-- Kolay -->
                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,6,0" MinWidth="90">
                        <Border.Background>
                            <SolidColorBrush Color="#10B981"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="🟢" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Kolay'}"
                                      FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Kolay" FontSize="10" Foreground="#D1FAE5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Orta -->
                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,6,0" MinWidth="90">
                        <Border.Background>
                            <SolidColorBrush Color="#F59E0B"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="🟡" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Orta'}"
                                      FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Orta" FontSize="10" Foreground="#FEF3C7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Zor -->
                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,6,0" MinWidth="90">
                        <Border.Background>
                            <SolidColorBrush Color="#EF4444"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="🔴" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Zor'}"
                                      FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Zor" FontSize="10" Foreground="#FEE2E2" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Çok Zor -->
                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,6,0" MinWidth="90">
                        <Border.Background>
                            <SolidColorBrush Color="#6B7280"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="⚫" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Çok Zor'}"
                                      FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Çok Zor" FontSize="10" Foreground="#E5E7EB" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Toplam Soru -->
                    <Border CornerRadius="8" Padding="12,10" Margin="6,0,0,0" MinWidth="90"
                            BorderBrush="{DynamicResource Accent}" BorderThickness="2">
                        <Border.Background>
                            <SolidColorBrush Color="#EFF6FF"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding QuestionDifficulties.Count}"
                                      FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Accent}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Toplam" FontSize="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Distribution Summary - Kompakt -->
                <Border Background="{DynamicResource AltRowBg}" CornerRadius="6" Padding="8" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dağılım:" FontSize="11" FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextMain}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding DifficultyDistribution}"
                                  FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- SORU LİSTESİ - Kartların hemen altında -->
        <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20" Margin="25,0,25,25"
                MinHeight="450">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="350"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📋 Soru Bazında Detaylı Analiz"
                          FontSize="18" FontWeight="Bold"
                          Foreground="{DynamicResource TextMain}" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled"
                              MinHeight="350">
                    <ItemsControl ItemsSource="{Binding QuestionDifficulties}">
                        <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10" 
                                           Padding="15" Margin="0,0,0,8" 
                                           BorderThickness="1" BorderBrush="{DynamicResource Border}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" 
                                                            Opacity="0.1" BlurRadius="4" ShadowDepth="1"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Soru Numarası -->
                                            <Border Grid.Column="0" Background="{Binding DifficultyColor}" 
                                                   CornerRadius="8" Padding="8">
                                                <TextBlock Text="{Binding QuestionNumber}" FontSize="16" FontWeight="Bold" 
                                                          Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Zorluk Seviyesi -->
                                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DifficultyIcon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DifficultyLevel}" FontSize="14" FontWeight="SemiBold" 
                                                              Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- Progress Bar -->
                                                <Border Background="{DynamicResource Border}" CornerRadius="4" 
                                                       Height="6" Margin="0,8,0,0">
                                                    <Border Background="{Binding DifficultyColor}" CornerRadius="4" 
                                                           Height="6" Width="{Binding SuccessRate, Converter={StaticResource ValueToWidthConverter}, ConverterParameter=200}"/>
                                                </Border>
                                            </StackPanel>
                                            
                                            <!-- Başarı Oranı -->
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SuccessRate, StringFormat=F1}" FontSize="16" FontWeight="Bold" 
                                                          Foreground="{Binding DifficultyColor}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="%" FontSize="12" Foreground="{DynamicResource TextMuted}" 
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Doğru Sayısı -->
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CorrectAnswers}" FontSize="16" FontWeight="SemiBold" 
                                                          Foreground="{DynamicResource Success}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Doğru" FontSize="11" Foreground="{DynamicResource TextMuted}" 
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Toplam -->
                                            <StackPanel Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TotalAnswers}" FontSize="16" FontWeight="SemiBold" 
                                                          Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Toplam" FontSize="11" Foreground="{DynamicResource TextMuted}" 
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Trend Icon -->
                                            <Border Grid.Column="5" Background="{Binding DifficultyColor, Converter={StaticResource DifficultyToBackgroundConverter}}" 
                                                   CornerRadius="6" Width="30" Height="30" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DifficultyIcon}" FontSize="14" 
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
    </DockPanel>
</UserControl>
