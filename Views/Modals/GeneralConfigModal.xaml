<UserControl x:Class="OptikFormApp.Views.Modals.GeneralConfigModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">
    <Grid Visibility="{Binding IsGeneralConfigOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="20" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="40" ShadowDepth="12"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#10B981" CornerRadius="20,20,0,0" Padding="30,25">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="⚙️  Sınav ve Puanlama Ayarları" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Okul adını, puan kuralını ve çıktı klasörünü ayarlayın." FontSize="13" Foreground="#A7F3D0" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="✕" Command="{Binding CloseGeneralConfigCommand}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" BorderThickness="0" Foreground="White"
                                FontSize="18" Padding="8,4" Cursor="Hand" Opacity="0.8"/>
                    </Grid>
                </Border>

                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="25,20,25,15">

                    <!-- Okul Adı Kartı -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,8">
                                <Run Text="🏫  "/> <Run Text="Okul / Kurum Adı"/>
                            </TextBlock>
                            <TextBox Text="{Binding SchoolName, UpdateSourceTrigger=PropertyChanged}" Padding="10,10"
                                     Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}"/>
                        </StackPanel>
                    </Border>

                    <!-- Puanlama Kartı -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,12">
                                <Run Text="📊  "/> <Run Text="Puanlama Parametreleri"/>
                            </TextBlock>

                            <TextBlock Text="Net Hesabı Kuralı (Düşüm)" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <ComboBox SelectedIndex="{Binding DeductionRuleIndex}" Margin="0,0,0,14" Padding="10,9"
                                      Background="{DynamicResource CardBg}">
                                <ComboBoxItem Content="🟢  Düşüm Yapılmasın (Net = Doğru)"/>
                                <ComboBoxItem Content="🟡  3 Yanlış 1 Doğru (0.33)"/>
                                <ComboBoxItem Content="🔴  4 Yanlış 1 Doğru (0.25 - Standart)"/>
                            </ComboBox>

                            <!-- Net Katsayı + Taban Puan -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="Net Katsayısı" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Text="1 net = kaç puan?" FontSize="11" Foreground="{DynamicResource TextMuted}" Opacity="0.6" Margin="0,2,0,6"/>
                                        <TextBox Text="{Binding NetCoefficient, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,8" HorizontalContentAlignment="Center"
                                                 FontWeight="Bold" FontSize="16" Foreground="#10B981"
                                                 Background="Transparent" BorderBrush="{DynamicResource Border}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="Taban Puan" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Text="Başlangıç puanı (Genelde 0)" FontSize="11" Foreground="{DynamicResource TextMuted}" Opacity="0.6" Margin="0,2,0,6"/>
                                        <TextBox Text="{Binding BaseScore, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,8" HorizontalContentAlignment="Center"
                                                 FontWeight="Bold" FontSize="16" Foreground="#3B82F6"
                                                 Background="Transparent" BorderBrush="{DynamicResource Border}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Excel Klasör Kartı -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20,16">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,8">
                                <Run Text="📁  "/> <Run Text="Varsayılan Excel Klasörü"/>
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding DefaultExcelPath}" Padding="10,9"
                                         Foreground="{DynamicResource TextMuted}" Background="{DynamicResource CardBg}"
                                         BorderBrush="{DynamicResource Border}"/>
                                <Button Grid.Column="2" Content="📂  Seç" Command="{Binding SelectFolderCommand}"
                                        Padding="14,9" Background="#3B82F6" Foreground="White" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{DynamicResource AltRowBg}" CornerRadius="0,0,20,20" Padding="25,15">
                    <Grid>
                        <TextBlock Text="💡  Ayarlar her açılışta otomatik yüklenir." FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <Button Content="Kaydet ve Kapat" Command="{Binding CloseGeneralConfigCommand}"
                                HorizontalAlignment="Right" Background="#10B981" Foreground="White"
                                Padding="25,8" FontSize="13"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
