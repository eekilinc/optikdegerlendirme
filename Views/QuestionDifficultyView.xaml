<UserControl x:Class="OptikFormApp.Views.QuestionDifficultyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header Section -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="📊 Soru Zorluk Seviyesi Analizi" 
                          FontSize="24" FontWeight="Bold" 
                          Foreground="{DynamicResource TextMain}" Margin="0,0,0,15"/>
                
                <!-- Modern Stats Cards -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Kolay -->
                    <Border Grid.Column="0" CornerRadius="12" Padding="20" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#10B981" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🟢" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Kolay" FontSize="14" FontWeight="SemiBold" 
                                      Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Kolay'}" 
                                      FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Soru" FontSize="12" Foreground="#E0F2FE" 
                                      HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Orta -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="20" Margin="8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#D97706" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#F59E0B" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🟡" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Orta" FontSize="14" FontWeight="SemiBold" 
                                      Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Orta'}" 
                                      FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Soru" FontSize="12" Foreground="#FEF3C7" 
                                      HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Zor -->
                    <Border Grid.Column="2" CornerRadius="12" Padding="20" Margin="8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EF4444" Offset="0"/>
                                <GradientStop Color="#DC2626" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#EF4444" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🔴" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Zor" FontSize="14" FontWeight="SemiBold" 
                                      Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Zor'}" 
                                      FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Soru" FontSize="12" Foreground="#FEE2E2" 
                                      HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Çok Zor -->
                    <Border Grid.Column="3" CornerRadius="12" Padding="20" Margin="8,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6B7280" Offset="0"/>
                                <GradientStop Color="#4B5563" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#6B7280" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="⚫" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Çok Zor" FontSize="14" FontWeight="SemiBold" 
                                      Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding QuestionDifficulties, Converter={StaticResource DifficultyCountConverter}, ConverterParameter='Çok Zor'}" 
                                      FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Soru" FontSize="12" Foreground="#F3F4F6" 
                                      HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Distribution Summary -->
                <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dağılım:" FontSize="14" FontWeight="SemiBold" 
                                  Foreground="{DynamicResource TextMain}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding DifficultyDistribution}" 
                                  FontSize="14" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Modern Data Grid -->
            <Border Grid.Row="2" Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="📋 Soru Bazında Detaylı Analiz" 
                              FontSize="18" FontWeight="Bold" 
                              Foreground="{DynamicResource TextMain}" Margin="0,0,0,20"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding QuestionDifficulties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10" 
                                           Padding="15" Margin="0,0,0,8" 
                                           BorderThickness="1" BorderBrush="{DynamicResource Border}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" 
                                                            Opacity="0.1" BlurRadius="4" ShadowDepth="1"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Soru Numarası -->
                                            <Border Grid.Column="0" Background="{Binding DifficultyColor}" 
                                                   CornerRadius="8" Padding="8">
                                                <TextBlock Text="{Binding QuestionNumber}" FontSize="16" FontWeight="Bold" 
                                                          Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Zorluk Seviyesi -->
                                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DifficultyIcon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DifficultyLevel}" FontSize="14" FontWeight="SemiBold" 
                                                              Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- Progress Bar -->
                                                <Border Background="{DynamicResource Border}" CornerRadius="4" 
                                                       Height="6" Margin="0,8,0,0">
                                                    <Border Background="{Binding DifficultyColor}" CornerRadius="4" 
                                                           Height="6" Width="{Binding SuccessRate, Converter={StaticResource ValueToWidthConverter}, ConverterParameter=200}"/>
                                                </Border>
                                            </StackPanel>
                                            
                                            <!-- Başarı Oranı -->
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SuccessRate, StringFormat=F1}" FontSize="16" FontWeight="Bold" 
                                                          Foreground="{Binding DifficultyColor}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="%" FontSize="12" Foreground="{DynamicResource TextMuted}" 
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Doğru Sayısı -->
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CorrectAnswers}" FontSize="16" FontWeight="SemiBold" 
                                                          Foreground="{DynamicResource Success}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Doğru" FontSize="11" Foreground="{DynamicResource TextMuted}" 
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Toplam -->
                                            <StackPanel Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TotalAnswers}" FontSize="16" FontWeight="SemiBold" 
                                                          Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Toplam" FontSize="11" Foreground="{DynamicResource TextMuted}" 
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Trend Icon -->
                                            <Border Grid.Column="5" Background="{Binding DifficultyColor, Converter={StaticResource DifficultyToBackgroundConverter}}" 
                                                   CornerRadius="6" Width="30" Height="30" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DifficultyIcon}" FontSize="14" 
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
