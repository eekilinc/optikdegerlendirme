<UserControl x:Class="OptikFormApp.Views.Modals.SaveExamModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="500">
    <Grid Visibility="{Binding IsSaveExamModalOpen, Converter={StaticResource BoolToVis}}" 
          Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" 
                CornerRadius="16" 
                Width="480" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="30" ShadowDepth="8"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Border Grid.Row="0" Background="#3B82F6" CornerRadius="16,16,0,0" Padding="25,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="White" CornerRadius="10" Width="40" Height="40" Padding="8" Margin="0,0,15,0">
                            <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Sınavı Kaydet" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Değerlendirme verilerini kaydedin" FontSize="13" Foreground="White" Opacity="0.9" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="25,20">
                    
                    <!-- Info Banner -->
                    <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Kaydedilen sınavlar seçili derste listelenir ve tekrar açılabilir." 
                                       FontSize="12" Foreground="{DynamicResource TextMain}" 
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Exam Name -->
                    <TextBlock Text="Sınav Adı" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewExamName, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,15" 
                             Padding="12,10" 
                             FontSize="14"
                             BorderThickness="1.5">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    
                    <!-- Course Selection with Add/Remove -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ders" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Courses}" 
                                      SelectedItem="{Binding SelectedCourseForSave}" 
                                      Padding="12,10" 
                                      FontSize="14">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📚" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Code}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                            <TextBlock Text="-" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Name}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <!-- Add Course Button -->
                        <Button Grid.Column="1" 
                                Content="➕ Yeni Ders" 
                                Command="{Binding ToggleAddCourseInlineCommand}"
                                VerticalAlignment="Bottom"
                                Margin="8,0,0,0"
                                Padding="12,10"
                                Background="#10B981"
                                Foreground="White"
                                FontSize="12"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Delete Course Button -->
                        <Button Grid.Column="2" 
                                Content="🗑️ Sil" 
                                Command="{Binding DeleteSelectedCourseInlineCommand}"
                                VerticalAlignment="Bottom"
                                Margin="8,0,0,0"
                                Padding="12,10"
                                Background="#EF4444"
                                Foreground="White"
                                FontSize="12"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                IsEnabled="{Binding SelectedCourseForSave, Converter={StaticResource NullToBool}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    
                    <!-- Inline Add Course Form -->
                    <Border Background="#F0FDF4" 
                            BorderBrush="#10B981" 
                            BorderThickness="1" 
                            CornerRadius="10" 
                            Padding="15" 
                            Margin="0,0,0,15"
                            Visibility="{Binding IsAddCourseInlineOpen, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" 
                                       Text="Yeni Ders Ekle" 
                                       FontSize="13" 
                                       FontWeight="Bold" 
                                       Foreground="#065F46"
                                       Margin="0,0,0,10"/>
                            
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Kodu" FontSize="11" Foreground="#059669" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding NewCourseCodeInline, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8"
                                             FontSize="13"
                                             MaxLength="10"
                                             CharacterCasing="Upper"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Adı" FontSize="11" Foreground="#059669" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding NewCourseNameInline, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8"
                                             FontSize="13"/>
                                </StackPanel>
                            </Grid>
                            
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="İptal" 
                                        Command="{Binding ToggleAddCourseInlineCommand}"
                                        Padding="15,8"
                                        Background="Transparent"
                                        BorderBrush="#059669"
                                        BorderThickness="1"
                                        Foreground="#059669"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Margin="0,0,8,0"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                
                                <Button Content="Ekle" 
                                        Command="{Binding AddCourseInlineCommand}"
                                        Padding="20,8"
                                        Background="#10B981"
                                        Foreground="White"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Setter Property="BorderBrush" Value="#10B981"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#064E3B"/>
                                        <Setter Property="BorderBrush" Value="#10B981"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    
                    <!-- Student Count Info -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="12,8" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" Margin="0,0,8,0"/>
                            <TextBlock Text="Kaydedilecek Öğrenci:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Students.Count, FallbackValue=0}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Footer Buttons -->
                <Border Grid.Row="2" Background="{DynamicResource AltRowBg}" CornerRadius="0,0,16,16" Padding="20,18" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Border}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" 
                                Content="Vazgeç" 
                                Command="{Binding CloseSaveExamModalCommand}" 
                                Style="{StaticResource OutlineButton}" 
                                Padding="20,10" FontSize="13"/>
                        
                        <Button Grid.Column="2" 
                                Content="💾 Sınavı Kaydet" 
                                Command="{Binding ConfirmSaveExamCommand}" 
                                IsEnabled="{Binding Students.Count}" 
                                Background="#3B82F6" 
                                Foreground="White" 
                                Padding="25,10" 
                                FontSize="13" 
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
