<UserControl x:Class="OptikFormApp.Views.Modals.ValidationDetailsModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">
    
    <Grid Background="{DynamicResource ModalBackdrop}">
        <Border Width="800" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="16"
                Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.3" BlurRadius="20" ShadowDepth="5"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="⚠️" FontSize="28" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="Veri Doğrulama Hataları" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="{Binding ValidationIssuesCount, StringFormat='Toplam {0} adet sorun tespit edildi'}" 
                                   FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Summary -->
                <Border Grid.Row="1" Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1" CornerRadius="8" 
                        Padding="12,10" Margin="0,0,0,15">
                    <TextBlock Text="Aşağıdaki tabloda tüm doğrulama hataları listelenmektedir. Her hata için öğrenci bilgisi, sorun türü ve detaylı açıklama görülmektedir." 
                               TextWrapping="Wrap" Foreground="#991B1B" FontSize="13"/>
                </Border>
                
                <!-- Error List -->
                <Border Grid.Row="2" Background="{DynamicResource AppBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
                        <ItemsControl ItemsSource="{Binding ValidationIssues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" 
                                            BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Severity Icon -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                                    Background="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                    Margin="0,0,15,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Severity, Converter={StaticResource SeverityToIconConverter}}" 
                                                           FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Details -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" 
                                                           Foreground="{DynamicResource TextMain}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Message}" FontSize="13" 
                                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock Text="📍 Etkilenen: " FontSize="12" Foreground="#7F1D1D" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding AffectedItems}" FontSize="12" Foreground="#7F1D1D"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                
                <!-- Footer Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="📋 Tümünü Kopyala" Padding="15,10" Margin="0,0,10,0" 
                            Background="#3B82F6" Foreground="White" FontWeight="SemiBold" FontSize="13"
                            Command="{Binding CopyValidationErrorsCommand}"/>
                    <Button Content="Kapat" Padding="20,10" 
                            Background="#DC2626" Foreground="White" FontWeight="SemiBold" FontSize="13"
                            Command="{Binding CloseValidationDetailsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
