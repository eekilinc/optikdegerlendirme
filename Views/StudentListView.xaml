<UserControl x:Class="OptikFormApp.Views.StudentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Search Bar -->
        <Border Grid.Row="0" Margin="0,5,0,15" Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.5"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                         FontSize="13" Foreground="{DynamicResource TextMain}">
                    <TextBox.Resources>
                        <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                            <VisualBrush.Visual>
                                <TextBlock Text="Öğrenci adı veya numarası ile ara..."/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </TextBox.Resources>
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="{x:Null}">
                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                </Trigger>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding StudentsView}" RowHeight="{Binding GridRowHeight}"
                  Visibility="{Binding Students.Count, Converter={StaticResource DataToVisConverter}}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="📄 Bu Öğrenci İçin PDF Karne Al" 
                              Command="{Binding DataContext.ExportSinglePdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                              CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="{Binding DataContext.GridCellPadding, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" SortMemberPath="RowNumber" Width="Auto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ÖĞRENCİ NO" Binding="{Binding StudentId}" SortMemberPath="StudentId" Width="Auto"/>
                <DataGridTextColumn Header="AD SOYAD" Binding="{Binding FullName}" SortMemberPath="FullName" Width="1.5*"/>
                <DataGridTextColumn Header="KİTAPÇIK" Binding="{Binding BookletType}" SortMemberPath="BookletType" Width="Auto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTemplateColumn Header="ÖĞRENCİ CEVAPLARI" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding ColoredAnswers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Character}" Foreground="{Binding State, Converter={StaticResource AnswerStateConverter}}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,1,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="D" Binding="{Binding CorrectCount}" SortMemberPath="CorrectCount" Width="50"/>
                <DataGridTextColumn Header="Y" Binding="{Binding IncorrectCount}" SortMemberPath="IncorrectCount" Width="50"/>
                <DataGridTextColumn Header="B" Binding="{Binding EmptyCount}" SortMemberPath="EmptyCount" Width="50"/>
                <DataGridTextColumn Header="SIRA" Binding="{Binding Rank}" SortMemberPath="Rank" Width="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="NET PUAN" Binding="{Binding Score, StringFormat={}{0:N2}}" SortMemberPath="Score" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- EMPTY STATE -->
        <Border Grid.Row="1" Visibility="{Binding Students.Count, Converter={StaticResource CountToVisConverter}}" 
                VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
            <StackPanel>
                <Border Width="80" Height="80" Background="{DynamicResource AltRowBg}" CornerRadius="40" Margin="0,0,0,20">
                    <TextBlock Text="📂" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Text="Kayıtlı Öğrenci Bulunamadı" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                <TextBlock Text="Henüz bir optik veri dosyası yüklenmemiş veya filtrelere uygun kayıt yok." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,10,0,25" TextAlignment="Center"/>
                <Button Content="Dosya Yükle (Ctrl+O)" Command="{Binding LoadTxtCommand}" Style="{StaticResource PipelineButton}" 
                        Background="#3B82F6" Foreground="White" Padding="25,12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
