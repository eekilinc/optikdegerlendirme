<Window x:Class="OptikFormApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptikFormApp.ViewModels"
        xmlns:views="clr-namespace:OptikFormApp.Views"
        xmlns:modals="clr-namespace:OptikFormApp.Views.Modals"
        Title="AĞLASUN MYO Optik Değerlendirme" Height="750" Width="1150" MinWidth="850" MinHeight="600"
        Icon="/Assets/app_logo.png"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource AppBg}" FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <!-- Dosya kısayolları -->
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding LoadTxtCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveExamCommand}" />
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExportExcelCommand}" />
        <KeyBinding Key="C" Modifiers="Ctrl+Shift" Command="{Binding ExportCsvCommand}" />
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding ExportPdfCommand}" />
        <!-- İşlem kısayolları -->
        <KeyBinding Key="F5" Command="{Binding EvaluateCommand}" />
        <KeyBinding Key="F1" Command="{Binding ShowShortcutsCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Window-specific Resources -->
    </Window.Resources>

    <Grid>
        <!-- APP SHELL -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Top Menu -->
                <RowDefinition Height="*"/>    <!-- Main View -->
            </Grid.RowDefinitions>

            <!-- MODERN TOP MENU -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                <Menu Background="Transparent" Padding="10,5">
                    <MenuItem Header="_Dosya">
                        <MenuItem Header="Optik Verisi Yükle (.txt)" Command="{Binding LoadTxtCommand}" InputGestureText="Ctrl+O"/>
                        <MenuItem Header="Sınavı Veritabanına Kaydet" Command="{Binding SaveExamCommand}" InputGestureText="Ctrl+S"/>
                        <Separator/>
                        <MenuItem Header="Excel Raporu Al (.xlsx)" Command="{Binding ExportExcelCommand}" InputGestureText="Ctrl+E"/>
                        <MenuItem Header="CSV Olarak Dışa Aktar (.csv)" Command="{Binding ExportCsvCommand}" InputGestureText="Ctrl+Shift+C"/>
                        <MenuItem Header="Not Listesi (No + Puan) (.csv)" Command="{Binding ExportGradeListCommand}"/>
                        <MenuItem Header="Toplu PDF Karne Al (.pdf)" Command="{Binding ExportPdfCommand}" InputGestureText="Ctrl+P"/>
                        <Separator/>
                        <MenuItem Header="Çıkış" Command="{Binding ExitCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Ders Yönetimi">
                        <MenuItem Header="Yeni Ders Ekle..." Command="{Binding ShowAddCourseCommand}"/>
                        <MenuItem Header="Seçili Dersi Sil" Command="{Binding DeleteCourseCommand}" CommandParameter="{Binding SelectedCourse}"/>
                    </MenuItem>
                    <MenuItem Header="_İşlemler">
                        <MenuItem Header="Cevap Anahtarlarını Yönet" Command="{Binding OpenModalCommand}"/>
                        <MenuItem Header="Soru Ayarlarını Yönet (İptal/Çoklu)" Command="{Binding OpenQuestionSettingsCommand}"/>
                        <MenuItem Header="Öğrenim Çıktılarını (Konu) Yönet" Command="{Binding OpenLearningOutcomesCommand}"/>
                        <Separator/>
                        <MenuItem Header="Puanları Hesapla" Command="{Binding EvaluateCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Seçenekler">
                        <MenuItem Header="Arayüz Ayarları..." Command="{Binding OpenUISettingsCommand}"/>
                        <MenuItem Header="Sınav ve Puanlama Ayarları..." Command="{Binding OpenGeneralConfigCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Yardım">
                        <MenuItem Header="Klavye Kısayolları" Command="{Binding ShowShortcutsCommand}" InputGestureText="F1"/>
                        <Separator/>
                        <MenuItem Header="Uygulama Hakkında..." Command="{Binding OpenAboutCommand}"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- SIDEBAR: COURSES & EXAMS -->
            <views:SidebarView Grid.Row="1" Grid.Column="0" />

            <!-- Main Content -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- MODERN WORKFLOW ACTION BAR -->
                <views:WorkflowView Grid.Row="0" />

                <!-- TAB CONTROL -->
                <Border Grid.Row="1" CornerRadius="12" Background="{DynamicResource CardBg}" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="15" ShadowDepth="2"/>
                    </Border.Effect>

                    <TabControl Background="Transparent" BorderThickness="0" Margin="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" Padding="20,12" BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="{DynamicResource CardBg}">
                                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                                    <Setter Property="TextElement.Foreground" Value="#3B82F6"/>
                                                    <Setter Property="TextElement.FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource TextMuted}"/>
                                                    <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextElement.Foreground" Value="#3B82F6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>
                        <!-- TAB 1: STUDENTS -->
                        <TabItem Header="İşlem Kayıtları">
                            <views:StudentListView />
                        </TabItem>

                        <!-- TAB 2: STATISTICS -->
                        <TabItem Header="Sınav İstatistikleri (Madde Analizi)">
                            <views:StatisticsView />
                        </TabItem>

                        <!-- TAB 3: CHARTS -->
                        <TabItem Header="Analiz Grafikleri (Görsel)">
                            <views:ChartsView />
                        </TabItem>

                        <!-- TAB 4: OUTCOMES -->
                        <TabItem Header="Kazanım Odaklı Başarı">
                            <views:OutcomesView />
                        </TabItem>
                    </TabControl>
                </Border>

                <!-- STATUS PANEL & LOGS (BOTTOM) -->
                <views:StatusPanelView Grid.Row="2" Margin="0,20,0,0" />
            </Grid>
        </Grid>

        <!-- BOOKLET SETTINGS MODAL OVERLAY -->
        <modals:BookletSettingsModal Panel.ZIndex="200" />

        <!-- SHORTCUTS MODAL OVERLAY -->
        <modals:ShortcutsModal Panel.ZIndex="250" />

        <!-- INTERFACE SETTINGS OVERLAY -->
        <modals:UISettingsModal Panel.ZIndex="300" />

        <!-- GENERAL CONFIG MODAL OVERLAY -->
        <modals:GeneralConfigModal Panel.ZIndex="500" />

        <!-- QUESTION SETTINGS MODAL OVERLAY -->
        <modals:QuestionSettingsModal Panel.ZIndex="400" />

        <!-- LEARNING OUTCOMES MODAL OVERLAY -->
        <modals:LearningOutcomesModal Panel.ZIndex="500" />

        <!-- ABOUT OVERLAY -->
        <modals:AboutModal Panel.ZIndex="600" />

        <!-- ADD COURSE MODAL OVERLAY -->
        <modals:AddCourseModal Panel.ZIndex="600" />

        <!-- RENAME MODAL OVERLAY -->
        <modals:RenameModal Panel.ZIndex="605" />

        <!-- BUSY LOADING OVERLAY -->
        <modals:BusyOverlay Panel.ZIndex="1000" />
    </Grid>
</Window>
