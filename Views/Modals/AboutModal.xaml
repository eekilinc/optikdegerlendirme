<UserControl x:Class="OptikFormApp.Views.Modals.AboutModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="480">
    <Grid Visibility="{Binding IsAboutOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="24" Width="460" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="50" ShadowDepth="15"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header with Gradient Background -->
                <Border Grid.Row="0" CornerRadius="24,24,0,0" Height="140">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#1D4ED8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <!-- Large Logo -->
                    <Border Width="120" Height="120" CornerRadius="24" Background="White" 
                            VerticalAlignment="Bottom" Margin="0,0,0,-40">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="20" ShadowDepth="8"/>
                        </Border.Effect>
                        <Image Source="/Assets/app_logo.png" Stretch="Uniform" Margin="22"/>
                    </Border>
                </Border>
                
                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="35,55,35,30">
                    <!-- Title -->
                    <TextBlock Text="Optik Değerlendirme" FontSize="26" FontWeight="Bold" 
                               Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                    
                    <!-- Version Badge -->
                    <Border Background="{DynamicResource Accent}" CornerRadius="15" Padding="15,5" 
                            HorizontalAlignment="Center" Margin="0,12,0,20">
                        <TextBlock Text="v2.1.0 Premium" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </Border>
                    
                    <!-- Description -->
                    <TextBlock Text="AĞLASUN MYO sınav değerlendirme süreçlerini dijitalleştirmek ve hızlandırmak amacıyla geliştirilmiş modern, hızlı ve kullanıcı dostu bir değerlendirme platformudur." 
                               FontSize="14" Foreground="{DynamicResource TextMain}" 
                               TextAlignment="Center" TextWrapping="Wrap" LineHeight="24"
                               Margin="0,0,0,25"/>
                    
                    <!-- Features Row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                        <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="12,8" Margin="0,0,8,0">
                            <TextBlock Text="⚡ Hızlı" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </Border>
                        <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="12,8" Margin="0,0,8,0">
                            <TextBlock Text="🔒 Güvenli" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </Border>
                        <Border Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="12,8">
                            <TextBlock Text="📊 Analitik" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- Developer Card -->
                    <Border Background="{DynamicResource AltRowBg}" CornerRadius="12" Padding="20,15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Geliştirici" FontSize="11" FontWeight="Bold" 
                                       Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Ekrem KILINÇ" FontSize="16" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource Accent}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Bilgisayar Programcılığı" FontSize="12" 
                                       Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- GitHub Link -->
                    <Button Command="{Binding OpenGitHubCommand}" 
                            Background="Transparent" BorderThickness="0" 
                            HorizontalAlignment="Center" Cursor="Hand"
                            Margin="0,0,0,20">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#24292E" CornerRadius="10" Padding="18,12"
                                        Cursor="Hand">
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Opacity)" 
                                                                     To="0.9" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- GitHub Icon -->
                                        <Path Data="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" 
                                              Fill="White" Stretch="Uniform" Width="22" Height="22"/>
                                        <TextBlock Text="github.com/eekilinc" FontSize="14" 
                                                   FontWeight="SemiBold" Foreground="White" 
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                
                <!-- Close Button -->
                <Button Grid.Row="2" Content="Kapat" Command="{Binding CloseAboutCommand}" 
                        Background="{DynamicResource Accent}" Foreground="White" 
                        Padding="50,12" HorizontalAlignment="Center" Margin="0,0,0,30"
                        FontSize="14" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
