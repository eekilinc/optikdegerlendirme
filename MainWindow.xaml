<Window x:Class="OptikFormApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptikFormApp.ViewModels"
        Title="AĞLASUN MYO Optik Değerlendirme" Height="750" Width="1150" MinWidth="850" MinHeight="600"
        Icon="/Assets/app_logo.png"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource AppBg}" FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:AnswerStateToBrushConverter x:Key="AnswerStateConverter"/>
        <vm:CountToVisibilityConverter x:Key="CountToVisConverter"/>
        <vm:ValueToHeightConverter x:Key="ValueHeightConverter"/>
        <vm:LogLevelToBrushConverter x:Key="LogLevelConverter"/>
        <vm:MultiValuePercentageConverter x:Key="MultiValuePercentageConverter"/>
        <vm:NullToVisibilityConverter x:Key="NullToVis"/>
        <vm:NullToVisibilityConverter x:Key="NotNullToVis" Invert="True"/>
        <vm:TrendToVisibilityConverter x:Key="GreaterThanZeroToVis" Mode="Positive"/>
        <vm:TrendToVisibilityConverter x:Key="LessThanZeroToVis" Mode="Negative"/>
        <vm:NumericToVisibilityConverter x:Key="NumericToVis"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PipelineButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Background="{DynamicResource CardBg}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="4">
                            <Grid>
                                <ContentPresenter x:Name="menuHeaderContainer" ContentTemplate="{TemplateBinding HeaderTemplate}" Content="{TemplateBinding Header}" ContentStringFormat="{TemplateBinding HeaderStringFormat}" ContentSource="Header" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="Fade" Placement="Bottom">
                                    <Border x:Name="SubMenuBorder" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6" Margin="0,5,0,0" Padding="5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <ScrollViewer x:Name="SubMenuScrollViewer" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                            <Grid RenderOptions.ClearTypeHint="Enabled">
                                                <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle"/>
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="PART_Popup" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="{DynamicResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Fill="{TemplateBinding Background}" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AltRowBg}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- APP SHELL -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Top Menu -->
                <RowDefinition Height="*"/>    <!-- Main View -->
            </Grid.RowDefinitions>

            <!-- MODERN TOP MENU -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                <Menu Background="Transparent" Padding="10,5">
                    <MenuItem Header="_Dosya">
                        <MenuItem Header="Optik Verisi Yükle (.txt)" Command="{Binding LoadTxtCommand}"/>
                        <MenuItem Header="Sınavı Veritabanına Kaydet" Command="{Binding SaveExamCommand}"/>
                        <Separator/>
                        <MenuItem Header="Excel Raporu Al (.xlsx)" Command="{Binding ExportExcelCommand}"/>
                        <MenuItem Header="Toplu PDF Karne Al (.pdf)" Command="{Binding ExportPdfCommand}"/>
                        <Separator/>
                        <MenuItem Header="Çıkış" Command="{Binding ExitCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Ders Yönetimi">
                        <MenuItem Header="Yeni Ders Ekle..." Command="{Binding ShowAddCourseCommand}"/>
                        <MenuItem Header="Seçili Dersi Sil" Command="{Binding DeleteCourseCommand}" CommandParameter="{Binding SelectedCourse}"/>
                    </MenuItem>
                    <MenuItem Header="_İşlemler">
                        <MenuItem Header="Cevap Anahtarlarını Yönet" Command="{Binding OpenModalCommand}"/>
                        <MenuItem Header="Soru Ayarlarını Yönet (İptal/Çoklu)" Command="{Binding OpenQuestionSettingsCommand}"/>
                        <MenuItem Header="Öğrenim Çıktılarını (Konu) Yönet" Command="{Binding OpenLearningOutcomesCommand}"/>
                        <Separator/>
                        <MenuItem Header="Puanları Hesapla" Command="{Binding EvaluateCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Seçenekler">
                        <MenuItem Header="Arayüz Ayarları..." Command="{Binding OpenUISettingsCommand}"/>
                        <MenuItem Header="Sınav ve Puanlama Ayarları..." Command="{Binding OpenGeneralConfigCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Yardım">
                        <MenuItem Header="Uygulama Hakkında..." Command="{Binding OpenAboutCommand}"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- SIDEBAR: COURSES & EXAMS -->
            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource HeaderBg}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- Courses Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="📚 Derslerim" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <Button Content="+" Command="{Binding ShowAddCourseCommand}" HorizontalAlignment="Right" Width="24" Height="24" Padding="0" Background="#3B82F6"/>
                    </Grid>

                    <!-- Course List -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse}" 
                             Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" CornerRadius="6" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Code}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextMain}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="✏" Command="{Binding DataContext.OpenRenameCourseCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMuted}" FontSize="13" Padding="8,0" Margin="0,0,2,0" Cursor="Hand" ToolTip="Dersi Düzenle"/>
                                            <Button Content="🗑" Command="{Binding DataContext.DeleteCourseCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="#EF4444" FontSize="13" Padding="8,0" Cursor="Hand" ToolTip="Bu dersi sil"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" BorderThickness="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppBg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Separator Grid.Row="2" Margin="0,15"/>

                    <!-- Exam History Header -->
                    <StackPanel Grid.Row="2" Margin="0,15,0,10">
                         <TextBlock Text="📁 Sınav Geçmişi" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                         <TextBlock Text="{Binding SelectedCourse.Name}" FontSize="11" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Exam List -->
                    <ListBox Grid.Row="3" ItemsSource="{Binding CourseExams}" SelectedItem="{Binding SelectedExam}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                                        <TextBlock Text="{Binding DisplayDate}" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="✏" Command="{Binding DataContext.OpenRenameExamCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMuted}" FontSize="10" Padding="5,0" Margin="0,0,2,0" Cursor="Hand" ToolTip="Sınavı Düzenle"/>
                                        <Button Content="🗑" Command="{Binding DataContext.DeleteExamCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="#EF4444" FontSize="10" Padding="5,0" Cursor="Hand" ToolTip="Bu sınavı sil"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- MODERN WORKFLOW ACTION BAR -->
                <Border Grid.Row="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="15" ShadowDepth="2"/>
                    </Border.Effect>
                    
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Left: Title -->
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,30,10">
                            <Border Width="45" Height="45" CornerRadius="10" Background="{DynamicResource AltRowBg}" Margin="0,0,15,0" Padding="5">
                                <Image Source="/Assets/app_logo.png" Stretch="Uniform"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="AĞLASUN MYO Optik Değerlendirme" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                <TextBlock Text="Optik okuma, test hesaplama ve raporlama adımlarını sırasıyla yönetin." FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right: Action Pipeline -->
                        <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                            
                            <Button Command="{Binding OpenModalCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,15,10" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBlock Text="Cevap Anahtarı"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenGeneralConfigCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,15,10" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBlock Text="Sınav Ayarları"/>
                                </StackPanel>
                            </Button>
                            
                             <Button Command="{Binding LoadTxtCommand}" Style="{StaticResource PipelineButton}" Background="{DynamicResource AltRowBg}" BorderBrush="{DynamicResource Border}" Foreground="{DynamicResource TextMain}" Margin="0,0,10,10" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" Margin="0,0,8,0"/>
                                    <TextBlock Text="1. Yükle" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <TextBox Text="{Binding NewExamName, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,0,10,10" VerticalAlignment="Stretch" Padding="8,0" Background="Transparent" Foreground="{DynamicResource TextMain}" BorderBrush="{DynamicResource Border}" ToolTip="Kaydedilecek Sınav Adı (Opsiyonel)">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                                <Setter Property="Tag" Value="Sınav adı (opsiyonel)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button Command="{Binding SaveExamCommand}" Style="{StaticResource PipelineButton}" IsEnabled="{Binding Students.Count}" Background="#10B981" BorderBrush="#059669" Foreground="White" Margin="0,0,10,10" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" Margin="0,0,8,0"/>
                                    <TextBlock Text="2. Kaydet" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Button.ToolTip>Sınav verilerini seçili dersin altına kalıcı olarak kaydeder.</Button.ToolTip>
                            </Button>
                            
                            <!-- Save Status Indicator -->
                            <Border Margin="0,0,10,10" Padding="10,6" CornerRadius="6" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Students.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasUnsavedData}" Value="True">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="✅ Kaydedildi"/>
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUnsavedData}" Value="True">
                                                    <Setter Property="Text" Value="⚠️ Kaydedilmedi"/>
                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            
                            <Button Command="{Binding EvaluateCommand}" Style="{StaticResource PipelineButton}" Background="#8B5CF6" BorderBrush="#7C3AED" Foreground="White" Margin="0,0,10,10" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" Margin="0,0,8,0"/>
                                    <TextBlock Text="3. Hesapla" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ExportExcelCommand}" Style="{StaticResource PipelineButton}" Background="#F59E0B" BorderBrush="#D97706" Foreground="White" Margin="0,0,10,10" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" Margin="0,0,8,0"/>
                                    <TextBlock Text="4. Excel" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </WrapPanel>
                </Border>

                <!-- TAB CONTROL -->
                <Border Grid.Row="1" CornerRadius="12" Background="{DynamicResource CardBg}" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="15" ShadowDepth="2"/>
                    </Border.Effect>

                    <TabControl Background="Transparent" BorderThickness="0" Margin="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" Padding="20,12" BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="{DynamicResource CardBg}">
                                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                                    <Setter Property="TextElement.Foreground" Value="#3B82F6"/>
                                                    <Setter Property="TextElement.FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource TextMuted}"/>
                                                    <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextElement.Foreground" Value="#3B82F6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- TAB 1: STUDENTS -->
                        <TabItem Header="İşlem Kayıtları">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Search Bar -->
                                <Border Grid.Row="0" Margin="0,5,0,15" Background="{DynamicResource AltRowBg}" CornerRadius="8" Padding="15,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.5"/>
                                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                                                 FontSize="13" Foreground="{DynamicResource TextMain}">
                                            <TextBox.Resources>
                                                <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Öğrenci adı veya numarası ile ara..."/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </TextBox.Resources>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="{x:Null}">
                                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding StudentsView}" RowHeight="{Binding GridRowHeight}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="📄 Bu Öğrenci İçin PDF Karne Al" 
                                                      Command="{Binding DataContext.ExportSinglePdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                      CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
