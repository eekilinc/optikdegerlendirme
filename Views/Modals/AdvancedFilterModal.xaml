<UserControl x:Class="OptikFormApp.Views.Modals.AdvancedFilterModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" d:DesignHeight="550" d:DesignWidth="480">
    
    <Grid Visibility="{Binding IsAdvancedFilterOpen, Converter={StaticResource BoolToVis}}"
          Background="#CC000000">
        
        <!-- Premium Modal -->
        <Border Width="440" 
                Height="550"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="24"
                Padding="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="60" ShadowDepth="20"/>
            </Border.Effect>
            
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Premium Header -->
                <Border Grid.Row="0" 
                        Height="70"
                        CornerRadius="16,16,0,0" 
                        Padding="0,0,0,16"
                        Margin="-28,-28,-28,0"
                        BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#06B6D4" Offset="0"/>
                            <GradientStop Color="#0891B2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#E2E8F0" Opacity="0.3"/>
                    </Border.BorderBrush>
                    
                    <Grid>
                        <TextBlock Text="🔍 Gelişmiş Filtreleme" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="24,0,0,0"/>
                        <Button Command="{Binding CloseAdvancedFilterCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Background="#20FFFFFF" 
                                BorderThickness="0" 
                                Foreground="White"
                                Width="36" 
                                Height="36"
                                FontSize="18" 
                                Padding="0"
                                Margin="0,0,24,0"
                                Cursor="Hand">
                            <Button.Content>✕</Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="18"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
                
                <Border Grid.Row="0" Margin="0,50,0,0" Background="Transparent"/>

                <!-- Score Range -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Min Puan" 
                                   FontSize="12"
                                   Margin="0,0,0,6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding MinScoreFilter, TargetNullValue=''}" 
                                 ToolTip="Minimum puan değeri"
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderThickness="1"
                                 BorderBrush="#E2E8F0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#0F172A"/>
                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                            <Setter Property="BorderBrush" Value="#334155"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" 
                               Text="-" 
                               VerticalAlignment="Bottom"
                               Margin="12,0"
                               FontSize="18"
                               FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max Puan" 
                                   FontSize="12"
                                   Margin="0,0,0,6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding MaxScoreFilter, TargetNullValue=''}" 
                                 ToolTip="Maximum puan değeri"
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderThickness="1"
                                 BorderBrush="#E2E8F0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#0F172A"/>
                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                            <Setter Property="BorderBrush" Value="#334155"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- Booklet Filter -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <TextBlock Text="Kitapçık Tipi" 
                               FontSize="12"
                               Margin="0,0,0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ComboBox ItemsSource="{Binding AvailableBookletTypes}"
                              SelectedItem="{Binding SelectedBookletFilter}"
                              ToolTip="Filtrelemek için kitapçık tipi seçin"
                              Padding="12,8"
                              FontSize="14"
                              BorderThickness="1"
                              BorderBrush="#E2E8F0">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#0F172A"/>
                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                        <Setter Property="BorderBrush" Value="#334155"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Correct/Wrong Count -->
                <Grid Grid.Row="3" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Min Doğru Sayısı" 
                                   FontSize="12"
                                   Margin="0,0,0,6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding MinCorrectFilter, TargetNullValue=''}" 
                                 ToolTip="Minimum doğru cevap sayısı"
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderThickness="1"
                                 BorderBrush="#E2E8F0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#0F172A"/>
                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                            <Setter Property="BorderBrush" Value="#334155"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max Yanlış Sayısı" 
                                   FontSize="12"
                                   Margin="0,0,0,6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding MaxWrongFilter, TargetNullValue=''}" 
                                 ToolTip="Maximum yanlış cevap sayısı"
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderThickness="1"
                                 BorderBrush="#E2E8F0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Background" Value="#0F172A"/>
                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                            <Setter Property="BorderBrush" Value="#334155"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- Sorting Card -->
                <Border Grid.Row="4" 
                        CornerRadius="14" 
                        Padding="16"
                        Margin="0,0,0,16"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#ECFEFF"/>
                            <Setter Property="BorderBrush" Value="#A5F3FC"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#164E63"/>
                                    <Setter Property="BorderBrush" Value="#155E75"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="32" 
                                    Height="32" 
                                    CornerRadius="8"
                                    Background="#06B6D4"
                                    Margin="0,0,10,0">
                                <TextBlock Text="📊" 
                                           FontSize="16" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Sıralama Ayarları" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#0E7490"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#67E8F9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ComboBox Grid.Column="0"
                                      SelectedItem="{Binding SelectedSortColumn}"
                                      Padding="12,8"
                                      FontSize="14"
                                      BorderThickness="1"
                                      BorderBrush="#A5F3FC">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Background" Value="#0F172A"/>
                                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                                <Setter Property="BorderBrush" Value="#155E75"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemsSource>
                                    <x:Array Type="{x:Type sys:String}">
                                        <sys:String>Puan</sys:String>
                                        <sys:String>Ad Soyad</sys:String>
                                        <sys:String>Öğrenci No</sys:String>
                                        <sys:String>Doğru Sayısı</sys:String>
                                        <sys:String>Yanlış Sayısı</sys:String>
                                        <sys:String>Net Sayısı</sys:String>
                                        <sys:String>Sıralama</sys:String>
                                    </x:Array>
                                </ComboBox.ItemsSource>
                            </ComboBox>
                            
                            <Button Grid.Column="1"
                                    Content="{Binding IsSortDescending, Converter={StaticResource SortDirectionConverter}}"
                                    Command="{Binding ToggleSortDirectionCommand}"
                                    Margin="10,0,0,0"
                                    Padding="14,8"
                                    ToolTip="Sıralama yönünü değiştir"
                                    Background="#06B6D4"
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Active Filters Summary -->
                <Border Grid.Row="5" 
                        CornerRadius="12" 
                        Padding="14"
                        Margin="0,0,0,16"
                        BorderThickness="1"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#DBEAFE"/>
                            <Setter Property="BorderBrush" Value="#BFDBFE"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#1E3A8A"/>
                                    <Setter Property="BorderBrush" Value="#1E40AF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ActiveFiltersSummary}" 
                                   TextWrapping="Wrap"
                                   FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Foreground" Value="#93C5FD"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Spacer -->
                <Grid Grid.Row="6" Height="10"/>

                <!-- Premium Footer -->
                <StackPanel Grid.Row="7" 
                            Grid.RowSpan="2"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                            <Button Content="🗑️ Filtreleri Temizle" 
                            Command="{Binding ClearFiltersCommand}"
                            Padding="16,14"
                            MinHeight="44"
                            Background="Transparent"
                            BorderBrush="#EF4444"
                            BorderThickness="2"
                            Foreground="#EF4444"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Margin="0,0,12,0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                            <Button Content="✓ Uygula ve Kapat" 
                            Command="{Binding CloseAdvancedFilterCommand}"
                            Padding="20,14"
                            MinHeight="44"
                            Background="#06B6D4"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
