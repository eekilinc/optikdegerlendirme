<UserControl x:Class="OptikFormApp.Views.Modals.AboutModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="480">
    
    <Grid Visibility="{Binding IsAboutOpen, Converter={StaticResource BoolToVis}}" 
          Background="#CC000000">
        
        <!-- Compact Professional Modal -->
        <Border Width="450" 
                MaxHeight="520"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                CornerRadius="16"
                Padding="0"
                Margin="20">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="40" ShadowDepth="15"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Compact Header with Logo -->
                <Border Grid.Row="0" 
                        Background="#3B82F6"
                        CornerRadius="16,16,0,0" 
                        Height="70"
                        Padding="20,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Small Logo -->
                        <Border Grid.Column="0" 
                                Width="48" 
                                Height="48" 
                                CornerRadius="10" 
                                Background="White">
                            <Image Source="/Assets/app_logo.png" Stretch="Uniform" Margin="6"/>
                        </Border>
                        
                        <!-- App Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Optik Değerlendirme" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="{Binding CurrentVersion}" 
                                       FontSize="12" 
                                       Opacity="0.9"
                                       Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Tab Content -->
                <TabControl Grid.Row="1" 
                            Margin="0"
                            BorderThickness="0"
                            Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="16,8"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>
                    
                    <!-- About Tab -->
                    <TabItem Header="ℹ️ Hakkında">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Modern optik sınav değerlendirme platformu. AĞLASUN MYO için geliştirilmiş, enterprise seviyesinde performans sunar." 
                                           FontSize="13" 
                                           TextWrapping="Wrap" 
                                           LineHeight="20"
                                           Margin="0,0,0,16">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <!-- Compact Features -->
                                <UniformGrid Columns="2" Margin="0,0,0,16">
                                    <Border CornerRadius="8" Padding="10,8" Margin="0,0,4,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                        <Setter Property="Background" Value="#1E3A5F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="⚡ Ultra Hızlı" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    
                                    <Border CornerRadius="8" Padding="10,8" Margin="4,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                        <Setter Property="Background" Value="#14532D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="🔒 Güvenli" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                            <Setter Property="Foreground" Value="#34D399"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    
                                    <Border CornerRadius="8" Padding="10,8" Margin="0,4,4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFFBEB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                        <Setter Property="Background" Value="#713F12"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="📊 Analitik" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                            <Setter Property="Foreground" Value="#FCD34D"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    
                                    <Border CornerRadius="8" Padding="10,8" Margin="4,4,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F5F3FF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                        <Setter Property="Background" Value="#581C87"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="💾 SQLite" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#8B5CF6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                            <Setter Property="Foreground" Value="#A78BFA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <!-- Update Tab -->
                    <TabItem Header="🔄 Güncelleme">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                            <StackPanel>
                                <Border CornerRadius="10" 
                                        Padding="14" 
                                        Margin="0,0,0,14"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUpdateAvailable}" Value="True">
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                    <Setter Property="BorderBrush" Value="#FCD34D"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Background" Value="#334155"/>
                                                    <Setter Property="BorderBrush" Value="#475569"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <StackPanel>
                                        <TextBlock Text="{Binding UpdateStatus}" 
                                                   FontSize="13"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUpdateAvailable}" Value="True">
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <Button Command="{Binding CheckForUpdatesCommand}"
                                                IsEnabled="{Binding IsCheckingForUpdate, Converter={StaticResource InverseBoolConverter}}"
                                                Padding="12,8"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#3B82F6"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Content" Value="🔍 Kontrol Et"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheckingForUpdate}" Value="True">
                                                            <Setter Property="Content" Value="⏳ Kontrol ediliyor..."/>
                                                            <Setter Property="Opacity" Value="0.7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasUpdateAvailable}" Value="True">
                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                            <Setter Property="Content" Value="📥 İndir"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                
                                <TextBlock Text="GitHub Releases üzerinden otomatik güncelleme kontrolü. Yeni sürümler için bildirim alın." 
                                           FontSize="11" 
                                           TextWrapping="Wrap"
                                           Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <!-- Developer Tab -->
                    <TabItem Header="👤 Geliştirici">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="64" 
                                        Height="64" 
                                        CornerRadius="32" 
                                        Background="#3B82F6"
                                        Margin="0,0,0,12">
                                    <TextBlock Text="EK" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                
                                <TextBlock Text="Ekrem KILINÇ" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <TextBlock Text="Full Stack Developer | .NET Expert" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <TextBlock Text="AĞLASUN MYO" 
                                           FontSize="11" 
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"
                                           Opacity="0.6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
                
                <!-- Close Button -->
                <Button Grid.Row="2" 
                        Command="{Binding CloseAboutCommand}" 
                        Background="Transparent"
                        HorizontalAlignment="Center" 
                        Margin="0,8,0,16"
                        Padding="40,10"
                        FontSize="13" 
                        FontWeight="SemiBold"
                        BorderThickness="1"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BorderBrush" Value="#CBD5E1"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="BorderBrush" Value="#475569"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Content>
                        <TextBlock Text="Kapat"/>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
