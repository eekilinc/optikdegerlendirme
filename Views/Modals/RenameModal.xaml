<UserControl x:Class="OptikFormApp.Views.Modals.RenameModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Grid Visibility="{Binding IsRenameModalOpen, Converter={StaticResource BoolToVis}}" Background="{DynamicResource ModalBackdrop}">
        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="5"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{Binding RenameModalTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,20"/>
                
                <!-- Input 1 Label - Ders için "Ders Kodu", Sınav için "Sınav Adı" -->
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Ad:"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowRenameInput2}" Value="True">
                                    <Setter Property="Text" Value="Ders Kodu:"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox Text="{Binding RenameInput1, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="10,8" FontSize="14"/>
                
                <!-- Input 2 - Sadece ders düzenlemede gösterilir -->
                <StackPanel Visibility="{Binding ShowRenameInput2, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Ders Adı:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding RenameInput2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" Padding="10,8" FontSize="14"/>
                </StackPanel>
                
                <!-- Boşluk sınav düzenlemede -->
                <Border Height="10" Visibility="{Binding ShowRenameInput2, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Vazgeç" Command="{Binding CloseRenameModalCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Kaydet" Command="{Binding SaveRenameCommand}" Background="#3B82F6" Margin="5,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
