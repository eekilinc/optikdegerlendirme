<UserControl x:Class="OptikFormApp.Views.Modals.ItemAnalysisModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OptikFormApp.Views.Modals"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Visibility="{Binding IsItemAnalysisOpen, Converter={StaticResource BoolToVis}}"
          Background="#CC000000">
        <Border Width="950" 
                Height="650"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="24"
                Padding="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="60" ShadowDepth="20"/>
            </Border.Effect>
            
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Premium Header -->
                <Border Grid.Row="0" 
                        Height="80"
                        CornerRadius="24,24,0,0" 
                        Padding="28,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F59E0B" Offset="0"/>
                            <GradientStop Color="#D97706" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <TextBlock Text="📊 Gelişmiş Soru Analizi" 
                                   FontSize="26" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                        <Button Command="{Binding CloseItemAnalysisCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Background="#20FFFFFF" 
                                BorderThickness="0" 
                                Foreground="White"
                                Width="36" 
                                Height="36"
                                FontSize="18" 
                                Padding="0"
                                Cursor="Hand">
                            <Button.Content>✕</Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="18"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Reliability Stats Cards -->
                <Grid Grid.Row="1" Margin="24,20,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- KR-20 Card -->
                    <Border Grid.Column="0" 
                            CornerRadius="16" 
                            Padding="20,16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FEF3C7"/>
                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#451A03"/>
                                        <Setter Property="BorderBrush" Value="#78350F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="KR-20 Güvenirlik" 
                                       FontSize="12" 
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#92400E"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#FCD34D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ReliabilityStats.KR20, StringFormat={}{0:F3}}" 
                                       FontSize="28" 
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D97706"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#FCD34D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Cronbach's Alpha Card -->
                    <Border Grid.Column="2" 
                            CornerRadius="16" 
                            Padding="20,16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#1E3A8A"/>
                                        <Setter Property="BorderBrush" Value="#1E40AF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Cronbach's Alpha" 
                                       FontSize="12" 
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#93C5FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ReliabilityStats.CronbachAlpha, StringFormat={}{0:F3}}" 
                                       FontSize="28" 
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#93C5FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Question Count Card -->
                    <Border Grid.Column="4" 
                            CornerRadius="16" 
                            Padding="20,16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="BorderBrush" Value="#475569"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Soru Sayısı" 
                                       FontSize="12" 
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ReliabilityStats.QuestionCount}" 
                                       FontSize="28" 
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Content Area -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Question Stats DataGrid -->
                    <Border Grid.Column="0" 
                            CornerRadius="16" 
                            Padding="16"
                            Margin="0,0,16,0"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="BorderBrush" Value="#475569"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DataGrid ItemsSource="{Binding QuestionStats}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProblematic}" Value="True">
                                            <Setter Property="Background" Value="#30EF4444"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Soru" 
                                                    Binding="{Binding QuestionNumber}" 
                                                    Width="50"/>
                                <DataGridTextColumn Header="Zorluk" 
                                                    Binding="{Binding Difficulty, StringFormat={}{0:P0}}" 
                                                    Width="70"/>
                                <DataGridTextColumn Header="Ayırt." 
                                                    Binding="{Binding Discrimination, StringFormat={}{0:F2}}" 
                                                    Width="70"/>
                                <DataGridTextColumn Header="Doğru" 
                                                    Binding="{Binding CorrectRate, StringFormat={}{0:P0}}" 
                                                    Width="70"/>
                                <DataGridTextColumn Header="Boş" 
                                                    Binding="{Binding EmptyRate, StringFormat={}{0:P0}}" 
                                                    Width="60"/>
                                <DataGridTextColumn Header="PB Korel." 
                                                    Binding="{Binding PointBiserialCorrelation, StringFormat={}{0:F2}}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Durum" 
                                                    Binding="{Binding Recommendation}" 
                                                    Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Anomalies Panel -->
                    <Border Grid.Column="1" 
                            CornerRadius="16" 
                            Padding="16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="BorderBrush" Value="#FECACA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#450A0A"/>
                                        <Setter Property="BorderBrush" Value="#7F1D1D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="32" 
                                        Height="32" 
                                        CornerRadius="8"
                                        Background="#EF4444"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="⚠️" 
                                               FontSize="16" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Tespit Edilen Anomaliler" 
                                           FontSize="15" 
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#991B1B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="#FCA5A5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Anomalies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" 
                                                    Padding="14" 
                                                    Margin="0,0,0,10"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="#FECACA"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                <Setter Property="Background" Value="#7F1D1D"/>
                                                                <Setter Property="BorderBrush" Value="#991B1B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <TextBlock Grid.Row="0" 
                                                               Text="{Binding FullName}" 
                                                               FontWeight="SemiBold" 
                                                               FontSize="14">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1E293B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Row="1" 
                                                               Text="{Binding StudentId}" 
                                                               FontSize="12" 
                                                               Margin="0,4">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Row="2" 
                                                               Text="{Binding Description}" 
                                                               FontSize="12" 
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#FCA5A5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <TextBlock Grid.Row="1" 
                                       Text="Anomali tespit edilmedi" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                <Setter Property="Foreground" Value="#64748B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.Visibility>
                                    <Binding Path="Anomalies.Count" Converter="{StaticResource CountToVisConverter}"/>
                                </TextBlock.Visibility>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Premium Footer -->
                <Border Grid.Row="3" 
                        CornerRadius="0,0,24,24" 
                        Padding="24,20"
                        Margin="-24,16,-24,-24"
                        BorderThickness="0,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter Property="Background" Value="#0F172A"/>
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🔄 Yeniden Analiz Et" 
                                Command="{Binding RunItemAnalysisCommand}"
                                Padding="18,10"
                                Background="Transparent"
                                BorderBrush="#F59E0B"
                                BorderThickness="2"
                                Foreground="#F59E0B"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Margin="0,0,12,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Kapat" 
                                Command="{Binding CloseItemAnalysisCommand}"
                                Padding="28,10"
                                Background="#F59E0B"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
