<UserControl x:Class="OptikFormApp.Views.Modals.BulkAnswerEntryModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="500">
    
    <Grid Visibility="{Binding IsBulkAnswerEntryOpen, Converter={StaticResource BoolToVis}}" 
          Background="#CC000000">
        
        <Border Width="450" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                CornerRadius="20"
                Padding="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="40" ShadowDepth="15"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" 
                        Height="70"
                        CornerRadius="20,20,0,0" 
                        Padding="24,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#7C3AED" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📋 Toplu Cevap Girişi" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="1 A, 2 B, 3 C formatında girin" 
                                       FontSize="12" 
                                       Foreground="#E9D5FF"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <Button Command="{Binding CloseBulkAnswerEntryCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Top"
                                Background="#20FFFFFF" 
                                BorderThickness="0" 
                                Foreground="White"
                                Width="32" 
                                Height="32"
                                FontSize="14" 
                                Padding="0"
                                Cursor="Hand">
                            <Button.Content>✕</Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="16"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="24,20">
                    
                    <!-- Info -->
                    <Border CornerRadius="10" 
                            Padding="12,10"
                            Margin="0,0,0,16"
                            Background="#F5F3FF"
                            BorderBrush="#DDD6FE"
                            BorderThickness="1">
                        <TextBlock Text="💡 Her satıra bir soru: '1 A' veya '5 C' şeklinde yazın. Boşluk veya tire ile ayırabilirsiniz."
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#7C3AED"/>
                    </Border>
                    
                    <!-- Input -->
                    <TextBlock Text="Cevaplar:" 
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="#64748B"/>
                    
                    <TextBox Text="{Binding BulkAnswerEntryText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="12"
                             Height="200"
                             VerticalScrollBarVisibility="Auto">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                        <Setter Property="Background" Value="#0F172A"/>
                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                        <Setter Property="BorderBrush" Value="#334155"/>
                                    </DataTrigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    
                    <!-- Preview -->
                    <TextBlock Text="{Binding BulkAnswerPreview, StringFormat='Önizleme: {0}'}" 
                               FontSize="11"
                               Margin="0,12,0,0"
                               FontStyle="Italic"
                               Foreground="#6B7280"/>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" 
                        CornerRadius="0,0,20,20" 
                        Padding="24,16"
                        BorderThickness="0,1,0,0"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button Content="İptal" 
                                Command="{Binding CloseBulkAnswerEntryCommand}"
                                Padding="18,10"
                                Background="Transparent"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                Foreground="#64748B"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Margin="0,0,10,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="✅ Uygula" 
                                Command="{Binding ApplyBulkAnswerEntryCommand}"
                                Padding="20,10"
                                Background="#8B5CF6"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
